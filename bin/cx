#!/usr/bin/env node
"use strict";

const { spawn } = require("child_process");
const fs = require("fs");
const os = require("os");
const path = require("path");

const home = os.homedir();
const packageVersion = readPackageVersion();

const timeoutMs = Number(process.env.CX_LIMIT_TIMEOUT_MS || 15000);
const autoMaxSwitches = Number(process.env.CX_AUTO_MAX_SWITCHES || 5);
const weeklySimilarDelta = 5;
const primarySimilarDelta = 20;
const rateLimitPattern = /Turn error:.*(?:usage limit|rate limit|limit reached|429)|You've hit your usage limit/i;
const defaultAccounts = initializeDefaultAccounts();
const continuationPrompt =
  "Continue the interrupted task from the last user instruction in this session. " +
  "The previous account hit a usage limit before completing the turn; do not ask the user to repeat it.";
const codexSubcommands = new Set([
  "exec",
  "e",
  "review",
  "login",
  "logout",
  "mcp",
  "plugin",
  "mcp-server",
  "app-server",
  "remote-control",
  "completion",
  "update",
  "doctor",
  "sandbox",
  "debug",
  "apply",
  "a",
  "resume",
  "archive",
  "unarchive",
  "fork",
  "cloud",
  "exec-server",
  "features",
  "help",
]);
const execSubcommands = new Set(["resume", "review", "help"]);
const globalValueOptions = new Set([
  "-c",
  "--config",
  "--enable",
  "--disable",
  "--remote",
  "--remote-auth-token-env",
  "-i",
  "--image",
  "-m",
  "--model",
  "--local-provider",
  "-p",
  "--profile",
  "-s",
  "--sandbox",
  "-C",
  "--cd",
  "--add-dir",
  "-a",
  "--ask-for-approval",
]);
const execResumeValueOptions = new Set([
  "-c",
  "--config",
  "--enable",
  "--disable",
  "-i",
  "--image",
  "-m",
  "--model",
  "--local-provider",
  "-p",
  "--profile",
  "--output-schema",
  "-o",
  "--output-last-message",
]);
const execAnalyzeValueOptions = new Set([...execResumeValueOptions, "--color"]);
const execResumeSupportedOptions = new Set([
  "--dangerously-bypass-approvals-and-sandbox",
  "--dangerously-bypass-hook-trust",
  "--disable",
  "--enable",
  "--ephemeral",
  "--ignore-rules",
  "--ignore-user-config",
  "--json",
