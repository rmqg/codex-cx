function readPackageVersion() {
  try {
    return JSON.parse(fs.readFileSync(path.join(__dirname, "..", "package.json"), "utf8")).version || "0.5.9";
  } catch {
    return "0.5.9";
  }
}

function usage() {
  console.log(`Usage:
  cx [codex args...]                         Auto-select account and auto-switch on limits.
  cx exec "prompt"                           Auto-select account and auto-switch on limits.
  cx auto [codex args...]                    Same as cx without --account.
  cx --account <selector> [codex args...]    Run only with one selected account.
  cx status
  cx --dry-run [codex args...]
  cx --no-bypass [codex args...]
  cx --no-trust [codex args...]

Environment:
  CX_ACCOUNT=1|account1|work                    Same as --account.
  CX_ACCOUNT_COUNT=N                            Probe ~/.codex-account1..N.
  CX_ACCOUNT_HOMES=/path/a,/path/b              Explicit comma-separated CODEX_HOME list.
  CX_NO_BYPASS=1                                Do not add the bypass flag.
  CX_NO_TRUST=1                                 Do not inject project trust for the current workdir.
  CX_AUTO_RESUME_GOAL=0                         Do not reactivate paused/limited goals before resume.
  CX_LIMIT_TIMEOUT_MS=15000                     Rate-limit probe timeout.
  CX_LIMIT_RETRIES=2                            Rate-limit probe attempts per account.
  CX_AUTO_MAX_SWITCHES=5                        Max automatic account switches per run.
  CX_INTERACTIVE_AUTO_EXEC=1                    Resume interrupted interactive turns in exec mode.
`);
}

function parseArgs(argv) {
  const codexArgs = [];
  const options = {
    auto: false,
    status: false,
    dryRun: false,
    noBypass: process.env.CX_NO_BYPASS === "1",
    noTrust: process.env.CX_NO_TRUST === "1",
    account: process.env.CX_ACCOUNT || null,
    accountExplicit: Boolean(process.env.CX_ACCOUNT),
  };

  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === "--") {
      codexArgs.push(...argv.slice(i + 1));
      break;
    }
    if ((arg === "-h" || arg === "--help") && codexArgs.length === 0) {
      usage();
      process.exit(0);
    }
    if (arg === "auto" || arg === "--auto" || arg === "--auto-switch") {
      options.auto = true;
      continue;
    }
    if (arg === "status" || arg === "--status") {
      options.status = true;
      continue;
    }
    if (arg === "--dry-run") {
      options.dryRun = true;
      continue;
    }
    if (arg === "--no-bypass") {
      options.noBypass = true;
      continue;
    }
    if (arg === "--no-trust") {
      options.noTrust = true;
      continue;
    }
    if (arg === "--account") {
      if (!argv[i + 1] || argv[i + 1].startsWith("-")) {
        const error = new Error("--account requires a selector");
        error.exitCode = 2;
        throw error;
      }
      options.account = argv[i + 1];
      options.accountExplicit = true;
      i += 1;
      continue;
    }
    if (arg.startsWith("--account=")) {
      options.account = arg.slice("--account=".length);
      options.accountExplicit = true;
      continue;
    }
    codexArgs.push(arg);
  }

  return { options, codexArgs };
}

function parsePositiveInteger(value, fallback, label) {
  if (value === undefined || value === null || value === "") {
    return fallback;
  }

  const parsed = Number(value);
  if (!Number.isInteger(parsed) || parsed < 1) {
    const error = new Error(`${label} must be a positive integer`);
    error.exitCode = 2;
    throw error;
  }
  return parsed;
}

function getRuntimeConfig() {
  if (!runtimeConfigCache) {
    runtimeConfigCache = {
      timeoutMs: parsePositiveInteger(process.env.CX_LIMIT_TIMEOUT_MS, 15000, "CX_LIMIT_TIMEOUT_MS"),
      limitRetries: parsePositiveInteger(process.env.CX_LIMIT_RETRIES, 2, "CX_LIMIT_RETRIES"),
      autoMaxSwitches: parsePositiveInteger(process.env.CX_AUTO_MAX_SWITCHES, 5, "CX_AUTO_MAX_SWITCHES"),
    };
  }
  return runtimeConfigCache;
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function naturalAccountSort(a, b) {
  const left = a.suffix.match(/^\d+$/) ? Number(a.suffix) : null;
  const right = b.suffix.match(/^\d+$/) ? Number(b.suffix) : null;
  if (left !== null && right !== null) {
    return left - right;
  }
  if (left !== null) {
    return -1;
  }
  if (right !== null) {
    return 1;
  }
  return a.name.localeCompare(b.name);
}

function expandHomePath(value) {
  if (value === "~") {
    return home;
  }
  if (value.startsWith("~/")) {
    return path.join(home, value.slice(2));
  }
  return path.resolve(value);
}

function discoveredAccountName(fileName, index) {
  const suffix = fileName.slice(".codex-account".length);
  if (/^\d+$/.test(suffix)) {
    return `account${suffix}`;
  }
  const trimmed = suffix.replace(/^-+/, "");
  return trimmed || `account${index + 1}`;
}

function discoverAccountHomes() {
  let entries;
  try {
    entries = fs.readdirSync(home, { withFileTypes: true });
  } catch {
    return [];
  }

  return entries
    .filter((entry) => entry.name.startsWith(".codex-account") && entry.name !== ".codex-account")
    .map((entry, index) => ({
      dirent: entry,
      name: discoveredAccountName(entry.name, index),
      suffix: entry.name.slice(".codex-account".length),
      home: path.join(home, entry.name),
    }))
    .filter((account) => {
      if (account.dirent.isDirectory() || account.dirent.isSymbolicLink()) {
        return true;
      }
      try {
        return fs.statSync(account.home).isDirectory();
      } catch {
        return false;
      }
    })
    .sort(naturalAccountSort)
    .map(({ name, home: accountHome }) => ({ name, home: accountHome }));
}

function buildDefaultAccounts() {
  const homes = process.env.CX_ACCOUNT_HOMES;
  if (homes) {
    const accounts = homes
      .split(",")
      .map((entry) => entry.trim())
      .filter(Boolean)
      .map((entry, index) => {
        const equals = entry.indexOf("=");
        if (equals >= 0) {
          const name = entry.slice(0, equals).trim() || `account${index + 1}`;
          const accountHome = entry.slice(equals + 1).trim();
          if (!accountHome) {
            throw new Error("CX_ACCOUNT_HOMES entries must include a path");
          }
          return { name, home: expandHomePath(accountHome) };
        }
        return { name: `account${index + 1}`, home: expandHomePath(entry) };
      });
    if (accounts.length < 1) {
      throw new Error("CX_ACCOUNT_HOMES requires at least one account home");
    }
    return validateAccounts(accounts, "CX_ACCOUNT_HOMES");
  }

  if (process.env.CX_ACCOUNT_COUNT) {
    const count = parsePositiveInteger(process.env.CX_ACCOUNT_COUNT, null, "CX_ACCOUNT_COUNT");
    return validateAccounts(Array.from({ length: count }, (_, index) => {
      const number = index + 1;
      return { name: `account${number}`, home: path.join(home, `.codex-account${number}`) };
    }), "CX_ACCOUNT_COUNT");
  }

  return validateAccounts(discoverAccountHomes(), "discovered accounts");
}

function validateAccounts(accounts, label) {
  const names = new Map();
  const homes = new Map();

  for (const account of accounts) {
    const normalizedName = account.name.toLowerCase();
    const normalizedHome = path.resolve(account.home);
    if (names.has(normalizedName)) {
      throw new Error(`${label} has duplicate account name: ${account.name}`);
    }
    if (homes.has(normalizedHome)) {
      throw new Error(`${label} has duplicate account home: ${normalizedHome}`);
    }
    names.set(normalizedName, account);
    homes.set(normalizedHome, account);
  }

  return accounts.map((account) => ({ ...account, home: path.resolve(account.home) }));
}

function safeAccountName(name) {
  return name.replace(/[^A-Za-z0-9_.-]/g, "_") || "account";
}

function getDefaultAccounts() {
  if (!defaultAccountsCache) {
    try {
      defaultAccountsCache = buildDefaultAccounts();
    } catch (error) {
      error.exitCode = error.exitCode || 2;
      throw error;
    }
  }
  return defaultAccountsCache;
}

function isPlausibleEmail(value) {
  return typeof value === "string" && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value.trim());
}

function findEmailValue(value, depth = 0) {
  if (!value || depth > 8) {
    return "";
  }
  if (Array.isArray(value)) {
    for (const item of value) {
      const email = findEmailValue(item, depth + 1);
      if (email) {
        return email;
      }
    }
    return "";
  }
  if (typeof value !== "object") {
    return "";
  }

  for (const [key, child] of Object.entries(value)) {
    if (key.toLowerCase() === "email" && isPlausibleEmail(child)) {
      return child.trim();
    }
  }
  for (const child of Object.values(value)) {
    const email = findEmailValue(child, depth + 1);
    if (email) {
      return email;
    }
  }
  return "";
}

function base64UrlDecode(value) {
  const normalized = value.replace(/-/g, "+").replace(/_/g, "/");
  const padded = normalized.padEnd(Math.ceil(normalized.length / 4) * 4, "=");
  return Buffer.from(padded, "base64").toString("utf8");
}

function extractJwtEmail(token) {
  if (typeof token !== "string") {
    return "";
  }
  const parts = token.split(".");
  if (parts.length < 2 || !parts[1]) {
    return "";
  }
  try {
    return findEmailValue(JSON.parse(base64UrlDecode(parts[1])));
  } catch {
    return "";
  }
}

function findJwtEmail(value, depth = 0) {
  if (!value || depth > 8) {
    return "";
  }
  if (typeof value === "string") {
    return extractJwtEmail(value);
  }
  if (Array.isArray(value)) {
    for (const item of value) {
      const email = findJwtEmail(item, depth + 1);
      if (email) {
        return email;
      }
    }
    return "";
  }
  if (typeof value === "object") {
    for (const child of Object.values(value)) {
      const email = findJwtEmail(child, depth + 1);
      if (email) {
        return email;
      }
    }
  }
  return "";
}

function extractAccountEmail(auth) {
  return findEmailValue(auth) || findJwtEmail(auth);
}

function readAccountEmail(account) {
  try {
    return extractAccountEmail(JSON.parse(fs.readFileSync(path.join(account.home, "auth.json"), "utf8")));
  } catch {
    return "";
  }
}

function accountDisplayName(account) {
  const email = readAccountEmail(account);
  return email ? `${account.name} (${email})` : account.name;
}

function accountSelectorHint(accounts = getDefaultAccounts()) {
  if (accounts.length < 1) {
    return "no accounts configured; run cx-setup --accounts <N> --migrate or set CX_ACCOUNT_HOMES";
  }
  const numeric = accounts.map((_, index) => String(index + 1)).join("|");
  const names = accounts.map((account) => account.name).join("|");
  return `${numeric}|${names}`;
}

function accountMatches(account, selector, accounts = getDefaultAccounts()) {
  if (!selector) {
    return false;
  }
  const normalized = String(selector).trim().toLowerCase();
  const index = accounts.indexOf(account);
  return (
    (index >= 0 && normalized === String(index + 1)) ||
    normalized === account.name.toLowerCase() ||
    normalized === account.name.replace(/^account/, "") ||
    normalized === path.basename(account.home).replace(/^\.codex-account/, "")
  );
}

async function readRateLimits(account, options = {}) {
  const authPath = path.join(account.home, "auth.json");
  if (!fs.existsSync(authPath)) {
    return Promise.resolve({ account, ok: false, error: `missing ${authPath}` });
  }

  const limitRetries = options.limitRetries || getRuntimeConfig().limitRetries;
  let lastError = null;
  for (let attempt = 1; attempt <= limitRetries; attempt += 1) {
    try {
      const result = await appServerRequest(account.home, "account/rateLimits/read", null);
      return { account, ok: true, limits: extractCodexLimit(result) };
    } catch (error) {
      lastError = error;
      if (attempt < limitRetries) {
        await sleep(500);
      }
    }
  }

  return { account, ok: false, error: lastError?.message || "rate-limit read failed" };
}

function appServerRequest(accountHome, method, params, options = {}) {
  return new Promise((resolve, reject) => {
    const timeoutMs = options.timeoutMs || getRuntimeConfig().timeoutMs;

    const env = { ...process.env, CODEX_HOME: accountHome };
    delete env.CODEX_THREAD_ID;

    const child = spawn("codex", ["app-server", "--listen", "stdio://"], {
      env,
      stdio: ["pipe", "pipe", "pipe"],
    });

    let buffer = "";
    let stderr = "";
    let settled = false;

    const timer = setTimeout(() => {
      finish(new Error(`timeout after ${timeoutMs}ms`));
    }, timeoutMs);

    function finish(error, result) {
      if (settled) {
        return;
      }
      settled = true;
      clearTimeout(timer);
      if (!child.killed) {
        child.kill("SIGTERM");
      }
      if (error) {
        reject(error);
      } else {
        resolve(result);
      }
    }

    function send(message) {
      child.stdin.write(`${JSON.stringify(message)}\n`);
    }

    child.on("error", (error) => finish(error));
    child.stderr.on("data", (chunk) => {
      stderr += chunk.toString();
      if (stderr.length > 4000) {
        stderr = stderr.slice(-4000);
      }
    });
    child.on("exit", (code) => {
      if (!settled && code !== 0) {
        finish(new Error(stderr.trim() || `codex app-server exited ${code}`));
      }
    });
    child.stdout.on("data", (chunk) => {
      buffer += chunk.toString();

      for (;;) {
        const newline = buffer.indexOf("\n");
        if (newline < 0) {
          break;
        }

        const line = buffer.slice(0, newline).trim();
        buffer = buffer.slice(newline + 1);
        if (!line) {
          continue;
        }

        let message;
        try {
          message = JSON.parse(line);
        } catch (error) {
          finish(new Error(`invalid JSON-RPC response: ${error.message}`));
          return;
        }

        if (message.id === "init") {
          if (message.error) {
            finish(new Error(message.error.message || "app-server initialize failed"));
            return;
          }
          send({ method: "initialized", params: {} });
          send({ id: "request", method, params });
          continue;
        }

        if (message.id === "request") {
          if (message.error) {
            finish(new Error(message.error.message || `${method} failed`));
          } else {
            finish(null, message.result);
          }
          return;
        }
      }
    });

    send({
      id: "init",
      method: "initialize",
      params: {
        clientInfo: { name: "cx", version: packageVersion },
        capabilities: { experimentalApi: true },
      },
    });
  });
}

function extractCodexLimit(result) {
  return (
    result?.rateLimitsByLimitId?.codex ||
    result?.rateLimits ||
    Object.values(result?.rateLimitsByLimitId || {})[0] ||
    null
  );
}

function usedPercent(limit, key) {
  const value = rawUsedPercent(limit, key);
  return Number.isFinite(value) ? value : 100;
}

function rawUsedPercent(limit, key) {
  const camelValue = limit?.[key]?.usedPercent;
  if (Number.isFinite(camelValue)) {
    return camelValue;
  }
  const snakeValue = limit?.[key]?.used_percent;
  return Number.isFinite(snakeValue) ? snakeValue : null;
}

function reached(limit) {
  if (!limit) {
    return "unknown";
  }
  return limit.rateLimitReachedType || limit.rate_limit_reached_type || "";
}

function normalizeReachedReason(reason) {
  const normalized = String(reason || "").toLowerCase();
  if (
    normalized === "primary" ||
    normalized === "primary_limit_reached" ||
    normalized === "workspace_owner_credits_depleted"
  ) {
    return "5h>=100%";
  }
  if (normalized === "secondary" || normalized === "secondary_limit_reached") {
    return "weekly>=100%";
  }
  return reason;
}

function limitExhaustedReason(result) {
  if (!result?.ok) {
    return result?.error || "probe failed";
  }
  if (!result.limits) {
    return "missing limits";
  }

  const reachedType = reached(result.limits);
  if (reachedType) {
    return normalizeReachedReason(reachedType);
  }

  const primary = rawUsedPercent(result.limits, "primary");
  if (Number.isFinite(primary) && primary >= 100) {
    return "5h>=100%";
  }

  const secondary = rawUsedPercent(result.limits, "secondary");
  if (Number.isFinite(secondary) && secondary >= 100) {
    return "weekly>=100%";
  }

  return "";
}

function isUsable(result) {
  return Boolean(result?.ok && result.limits && !limitExhaustedReason(result));
}

function getProcessActiveAccountNames() {
  const names = new Set();
  const accounts = getDefaultAccounts();
  let pids;
  try {
    pids = fs.readdirSync("/proc").filter((entry) => /^\d+$/.test(entry));
  } catch {
    return names;
  }

  for (const pid of pids) {
    try {
      const cmdline = fs.readFileSync(`/proc/${pid}/cmdline`, "utf8").split("\0").filter(Boolean);
      const command = cmdline.join(" ");
      if (!command.includes("codex") || command.includes("app-server")) {
        continue;
      }
      const environ = fs.readFileSync(`/proc/${pid}/environ`, "utf8").split("\0").filter(Boolean);
      const codexHome = environ
        .map((entry) => entry.match(/^CODEX_HOME=(.*)$/))
        .find(Boolean)?.[1];
      if (!codexHome) {
        continue;
      }
      const account = accounts.find((candidate) => path.resolve(candidate.home) === path.resolve(codexHome));
      if (account) {
        names.add(account.name);
      }
    } catch {
      // Processes can exit while we scan /proc.
    }
  }

  return names;
}

function getActiveAccountNames() {
  return getProcessActiveAccountNames();
}

function compareAccountResults(a, b) {
  const aUsable = isUsable(a);
  const bUsable = isUsable(b);
  if (aUsable !== bUsable) {
    return aUsable ? -1 : 1;
  }

  const aSecondary = usedPercent(a.limits, "secondary");
  const bSecondary = usedPercent(b.limits, "secondary");
  const secondaryDelta = aSecondary - bSecondary;
  if (Math.abs(secondaryDelta) > weeklySimilarDelta) {
    return secondaryDelta;
  }

  const aPrimary = usedPercent(a.limits, "primary");
  const bPrimary = usedPercent(b.limits, "primary");
  const primaryDelta = aPrimary - bPrimary;
  if (Math.abs(primaryDelta) > primarySimilarDelta) {
    return primaryDelta;
  }

  if (a.active !== b.active) {
    return a.active ? 1 : -1;
  }

  if (primaryDelta !== 0) {
    return primaryDelta;
  }

  if (secondaryDelta !== 0) {
    return secondaryDelta;
  }

  return a.account.name.localeCompare(b.account.name);
}

function formatPercent(value) {
  return `${Number.isFinite(value) ? value : 100}%`;
}

function printStatus(results) {
  console.error(
    `Selection rule: weekly delta > ${weeklySimilarDelta}% wins; within ${weeklySimilarDelta}% use 5h; ` +
      `5h delta <= ${primarySimilarDelta}% prefers inactive accounts; exhausted accounts are skipped.`,
  );
  console.error("Account   active   5h used   weekly used   reached   home");
  for (const result of results.slice().sort(compareAccountResults)) {
    const limit = result.limits;
    const active = result.active ? "yes" : "-";
    const primary = result.ok ? formatPercent(usedPercent(limit, "primary")) : "ERR";
    const secondary = result.ok ? formatPercent(usedPercent(limit, "secondary")) : "ERR";
    const hit = limitExhaustedReason(result) || "-";
    console.error(
      `${result.account.name.padEnd(9)} ${active.padEnd(8)} ${primary.padEnd(9)} ${secondary.padEnd(13)} ${String(hit).padEnd(9)} ${result.account.home}`,
    );
  }
}

function printNoAccountsConfigured() {
  console.error("[cx] No Codex account homes found.");
  console.error("[cx] On a new machine, run: cx-setup --accounts <N> --migrate");
  console.error("[cx] Or set: CX_ACCOUNT_HOMES=name=/path/to/codex-home,name2=/path/to/other-home");
}

function hasSafetyOverride(args) {
  return args.some((arg) =>
    arg === "--dangerously-bypass-approvals-and-sandbox" ||
    arg === "--sandbox" ||
    arg.startsWith("--sandbox=") ||
    arg === "--approval-policy" ||
    arg.startsWith("--approval-policy=") ||
    arg === "--ask-for-approval" ||
    arg.startsWith("--ask-for-approval=") ||
    arg === "-s" ||
    arg === "-a"
  );
}

function cwdFromOptionArgs(optionArgs, fallback = process.cwd()) {
  let cwd = fallback;
  for (let index = 0; index < optionArgs.length; index += 1) {
    const arg = optionArgs[index];
    if (arg === "-C" || arg === "--cd") {
      if (optionArgs[index + 1]) {
        cwd = expandHomePath(optionArgs[index + 1]);
        index += 1;
      }
      continue;
    }
    if (arg.startsWith("--cd=")) {
      cwd = expandHomePath(arg.slice("--cd=".length));
    }
  }
  return path.resolve(cwd);
}

function cwdFromCodexArgs(args) {
  const leading = splitLeadingOptions(args, 0, globalValueOptions);
  let cwd = cwdFromOptionArgs(leading.options);
  const command = args[leading.index];

  if (command === "exec" || command === "e") {
    const execValueOptionsWithCwd = new Set([...execAnalyzeValueOptions, "-C", "--cd", "--add-dir"]);
    const execOptions = splitLeadingOptions(args, leading.index + 1, execValueOptionsWithCwd);
    return cwdFromOptionArgs(execOptions.options, cwd);
  }

  if (command === "resume") {
    const resumeOptions = splitLeadingOptions(args, leading.index + 1, globalValueOptions);
    return cwdFromOptionArgs(resumeOptions.options, cwd);
  }

  return cwd;
}

function projectTrustConfigArg(codexArgs) {
  const cwd = cwdFromCodexArgs(codexArgs);
  return `projects.${JSON.stringify(cwd)}.trust_level="trusted"`;
}

function baseGlobalArgs(options, codexArgs, extraGlobalArgs = []) {
  const globalArgs = [];
  if (!options.noBypass && !hasSafetyOverride(codexArgs)) {
    globalArgs.push("--dangerously-bypass-approvals-and-sandbox");
  }
  if (!options.noTrust) {
    globalArgs.push("-c", projectTrustConfigArg(codexArgs));
  }
  return [...globalArgs, ...extraGlobalArgs];
}

function selectResult(results) {
  return results.slice().sort(compareAccountResults).find(isUsable) || null;
}

function optionName(arg) {
  const equals = arg.indexOf("=");
  return equals >= 0 ? arg.slice(0, equals) : arg;
}

function splitLeadingOptions(args, start, valueOptions) {
  const options = [];
  let index = start;

  while (index < args.length) {
    const arg = args[index];
    if (arg === "--") {
      break;
    }
    if (!arg.startsWith("-") || arg === "-") {
      break;
    }

    options.push(arg);
    if (!arg.includes("=") && valueOptions.has(optionName(arg)) && index + 1 < args.length) {
      index += 1;
      options.push(args[index]);
    }
    index += 1;
  }

  return { options, index };
}

function filterOptions(args, supportedOptions, valueOptions) {
  const filtered = [];
  for (let index = 0; index < args.length; index += 1) {
    const arg = args[index];
    const name = optionName(arg);
    const supported = supportedOptions.has(name);

    if (supported) {
      filtered.push(arg);
    }
    if (!arg.includes("=") && valueOptions.has(name) && index + 1 < args.length) {
      index += 1;
      if (supported) {
        filtered.push(args[index]);
      }
    }
  }
  return filtered;
}

function hasOption(args, name) {
  return args.some((arg) => optionName(arg) === name);
}

function isResumeInvocation(args) {
  const leading = splitLeadingOptions(args, 0, globalValueOptions);
  const command = args[leading.index] || null;
  if (command === "resume") {
    return true;
  }
  if (command !== "exec" && command !== "e") {
    return false;
  }
  const execOptions = splitLeadingOptions(args, leading.index + 1, execAnalyzeValueOptions);
  return args[execOptions.index] === "resume";
}

function filterResumePassthroughOptions(args) {
  return args.filter((arg) => optionName(arg) !== "--last");
}

function resumeTargetFromOptionsAndRest(options, rest) {
  const useLast = hasOption(options, "--last") || rest.length === 0;
  return {
    prompt: useLast ? rest.join(" ") || null : rest.slice(1).join(" ") || null,
    resumeTargetArgs: useLast ? ["--last"] : [rest[0]],
  };
}

function analyzeCodexArgs(args) {
  const leading = splitLeadingOptions(args, 0, globalValueOptions);
  const command = args[leading.index] || null;

  if (command === "exec" || command === "e") {
    const execOptions = splitLeadingOptions(args, leading.index + 1, execAnalyzeValueOptions);
    const execCommand = args[execOptions.index] || null;
    if (execCommand === "resume") {
      const resumeOptions = splitLeadingOptions(args, execOptions.index + 1, execResumeValueOptions);
      const allResumeOptions = [...execOptions.options, ...resumeOptions.options];
      const rest = args.slice(resumeOptions.index);
      const resumeTarget = resumeTargetFromOptionsAndRest(allResumeOptions, rest);

      return {
        mode: "exec",
        globalArgs: leading.options,
        resumeOptions: filterOptions(
          filterResumePassthroughOptions(allResumeOptions),
          execResumeSupportedOptions,
          execAnalyzeValueOptions,
        ),
        ...resumeTarget,
      };
    }

    const prompt =
      execCommand && execSubcommands.has(execCommand) ? null : args.slice(execOptions.index).join(" ") || null;
    return {
      mode: "exec",
      globalArgs: leading.options,
      resumeOptions: filterOptions(execOptions.options, execResumeSupportedOptions, execAnalyzeValueOptions),
      resumeTargetArgs: ["--last"],
      prompt,
    };
  }

  if (command === "resume") {
    const resumeOptions = splitLeadingOptions(args, leading.index + 1, globalValueOptions);
    const rest = args.slice(resumeOptions.index);
    const resumeTarget = resumeTargetFromOptionsAndRest(resumeOptions.options, rest);
    return {
      mode: "interactive",
      globalArgs: leading.options,
      resumeOptions: filterResumePassthroughOptions(resumeOptions.options),
      ...resumeTarget,
    };
  }

  if (command && codexSubcommands.has(command)) {
    return {
      mode: "interactive",
      globalArgs: leading.options,
      resumeOptions: [],
      resumeTargetArgs: ["--last"],
      prompt: null,
    };
  }

  return {
    mode: "interactive",
    globalArgs: leading.options,
    resumeOptions: [],
    resumeTargetArgs: ["--last"],
    prompt: args.slice(leading.index).join(" ") || null,
  };
}

function findLatestSessionFile(accountHome, options = {}) {
  const root = path.join(accountHome, "sessions");
  const minMtimeMs = options.minMtimeMs || 0;
  const cwd = options.cwd ? path.resolve(options.cwd) : null;
  const stack = [root];
  let latest = null;

  while (stack.length > 0) {
    const current = stack.pop();
    let entries;
    try {
      entries = fs.readdirSync(current, { withFileTypes: true });
    } catch {
      continue;
    }

    for (const entry of entries) {
      const target = path.join(current, entry.name);
      if (entry.isDirectory()) {
        stack.push(target);
        continue;
      }
      if (!entry.isFile() || !entry.name.endsWith(".jsonl")) {
        continue;
      }

      let stat;
      try {
        stat = fs.statSync(target);
      } catch {
        continue;
      }
      if (stat.mtimeMs < minMtimeMs) {
        continue;
      }
      if (!latest || stat.mtimeMs > latest.mtimeMs) {
        if (cwd) {
          const meta = readSessionMeta(target);
          if (!meta.cwd || path.resolve(meta.cwd) !== cwd) {
            continue;
          }
        }
        latest = { file: target, mtimeMs: stat.mtimeMs };
      }
    }
  }

  return latest?.file || null;
}

function readSessionMeta(file) {
  let fd;
  try {
    fd = fs.openSync(file, "r");
    const buffer = Buffer.alloc(1024 * 1024);
    const bytesRead = fs.readSync(fd, buffer, 0, buffer.length, 0);
    const firstLine = buffer.subarray(0, bytesRead).toString("utf8").split(/\r?\n/, 1)[0];
    if (!firstLine.trim()) {
      return {};
    }

    const event = JSON.parse(firstLine);
    const payload = event.payload || event;
    if (event.type !== "session_meta" && payload.type !== "session_meta") {
      return {};
    }
    return {
      id: payload.id || null,
      cwd: payload.cwd || null,
    };
  } catch {
    return {};
  } finally {
    if (fd !== undefined) {
      try {
        fs.closeSync(fd);
      } catch {
        // Ignore close failures while reading optional metadata.
      }
    }
  }
}

function tokenCountHasUsageLimit(payload) {
  const rateLimits = payload?.rate_limits;
  if (!rateLimits) {
    return false;
  }
  if (rateLimits.credits?.has_credits === false) {
    return true;
  }
  if (rateLimits.rate_limit_reached_type) {
    return true;
  }
  return false;
}

function latestSessionTurnState(accountHome, options = {}) {
  const file = findLatestSessionFile(accountHome, options);
  if (!file) {
    return { file: null, incomplete: false };
  }
  const meta = readSessionMeta(file);

  const state = {
    file,
    sessionId: meta.id || null,
    cwd: meta.cwd || null,
    activeTurn: false,
    sawUser: false,
    sawAssistant: false,
    sawWork: false,
    completed: false,
    lastAgentMessage: null,
    usageLimited: false,
  };

  let lines;
  try {
    lines = fs.readFileSync(file, "utf8").trimEnd().split("\n");
  } catch {
    return { file, incomplete: false };
  }

  for (const line of lines) {
    if (!line.trim()) {
      continue;
    }

    let event;
    try {
      event = JSON.parse(line);
    } catch {
      continue;
    }

    const payload = event.payload || event;
    if (event.type === "event_msg" && payload.type === "task_started") {
      state.activeTurn = true;
      state.sawUser = false;
      state.sawAssistant = false;
      state.sawWork = false;
      state.completed = false;
      state.lastAgentMessage = null;
      state.usageLimited = false;
      continue;
    }
    if (event.type === "event_msg" && payload.type === "task_complete") {
      state.completed = true;
      state.lastAgentMessage = payload.last_agent_message || null;
      if (state.lastAgentMessage) {
        state.sawAssistant = true;
      }
      continue;
    }

    if (!state.activeTurn) {
      continue;
    }

    if (
      (event.type === "response_item" && payload.type === "message" && payload.role === "user") ||
      (event.type === "event_msg" && payload.type === "user_message")
    ) {
      state.sawUser = true;
    } else if (event.type === "response_item" && payload.type === "message" && payload.role === "assistant") {
      state.sawAssistant = true;
    } else if (
      event.type === "response_item" &&
      ["function_call", "custom_tool_call", "local_shell_call"].includes(payload.type)
    ) {
      state.sawWork = true;
    } else if (event.type === "event_msg" && payload.type === "agent_message") {
      state.sawAssistant = true;
    } else if (event.type === "event_msg" && payload.type === "token_count" && tokenCountHasUsageLimit(payload)) {
      state.usageLimited = true;
    }
  }

  const sawTurnContent = state.sawUser || state.sawAssistant || state.sawWork;
  const completedByUsageLimit =
    state.completed &&
    state.sawUser &&
    !state.lastAgentMessage &&
    (state.usageLimited || options.assumeUsageLimited);

  return {
    ...state,
    incomplete: state.activeTurn && ((!state.completed && sawTurnContent) || completedByUsageLimit),
  };
}

function retryTargetFromSession(analysis, sessionState) {
  if (!sessionState.sessionId) {
    return analysis;
  }

  const targetArgs = analysis.resumeTargetArgs || ["--last"];
  const currentTarget = targetArgs[0];
  if (currentTarget && currentTarget !== "--last") {
    return analysis;
  }

  return { ...analysis, resumeTargetArgs: [sessionState.sessionId] };
}

function resumeArgsFromAnalysis(analysis, prompt) {
  if (analysis.mode === "exec") {
    return [
      ...analysis.globalArgs,
      "exec",
      "resume",
      ...analysis.resumeOptions,
      ...(analysis.resumeTargetArgs || ["--last"]),
      ...(prompt ? [prompt] : []),
    ];
  }

  return [
    ...analysis.globalArgs,
    "resume",
    ...analysis.resumeOptions,
    ...(analysis.resumeTargetArgs || ["--last"]),
    ...(prompt ? [prompt] : []),
  ];
}

function sessionRelativePath(accountHome, file) {
  if (!file) {
    return null;
  }
  const root = path.join(accountHome, "sessions");
  const relative = path.relative(root, file);
  if (!relative || relative.startsWith("..") || path.isAbsolute(relative) || !relative.endsWith(".jsonl")) {
    return null;
  }
  return relative;
}

function retrySessionFromState(accountHome, sessionState) {
  const relativePath = sessionRelativePath(accountHome, sessionState.file);
  if (!relativePath) {
    return null;
  }
  return {
    sourceHome: accountHome,
    file: sessionState.file,
    relativePath,
    sessionId: sessionState.sessionId || null,
  };
}

function ensureRetrySessionAvailable(retrySession, account) {
  if (!retrySession?.file || !retrySession.relativePath) {
    return;
  }

  const targetFile = path.join(account.home, "sessions", retrySession.relativePath);
  if (fs.existsSync(targetFile)) {
    return;
  }

  try {
    fs.mkdirSync(path.dirname(targetFile), { recursive: true });
    fs.copyFileSync(retrySession.file, targetFile, fs.constants.COPYFILE_EXCL);
    console.error(`[cx-auto] copied interrupted session to ${account.name}.`);
  } catch (error) {
    if (fs.existsSync(targetFile)) {
      return;
    }
    console.error(`[cx-auto] session sync failed for ${account.name}: ${error.message}`);
  }
}

function execResumeArgsFromInteractiveAnalysis(analysis, prompt) {
  const resumeOptions = filterOptions(analysis.resumeOptions, execResumeSupportedOptions, execAnalyzeValueOptions);
  return [
    ...analysis.globalArgs,
    "exec",
    "resume",
    ...resumeOptions,
    ...(analysis.resumeTargetArgs || ["--last"]),
    ...(prompt ? [prompt] : []),
  ];
}

function cwdFromGlobalArgs(globalArgs) {
  let cwd = process.cwd();
  for (let index = 0; index < globalArgs.length; index += 1) {
    const arg = globalArgs[index];
    if (arg === "-C" || arg === "--cd") {
      if (globalArgs[index + 1]) {
        cwd = expandHomePath(globalArgs[index + 1]);
        index += 1;
      }
      continue;
    }
    if (arg.startsWith("--cd=")) {
      cwd = expandHomePath(arg.slice("--cd=".length));
    }
  }
  return path.resolve(cwd);
}

function isUuidLike(value) {
  return /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(String(value || ""));
}

function resolveResumeThreadId(accountHome, analysis) {
  const targetArgs = analysis.resumeTargetArgs || ["--last"];
  const target = targetArgs[0];
  if (target && target !== "--last") {
    return isUuidLike(target) ? target : null;
  }

  const file = findLatestSessionFile(accountHome, {
    cwd: hasOption(analysis.resumeOptions || [], "--all") ? null : cwdFromGlobalArgs(analysis.globalArgs || []),
  });
  return file ? readSessionMeta(file).id || null : null;
}

function shouldResumeGoalStatus(status) {
  return status === "paused" || status === "usageLimited" || status === "blocked";
}

async function resumeGoalIfNeeded(account, codexArgs) {
  if (process.env.CX_AUTO_RESUME_GOAL === "0" || !isResumeInvocation(codexArgs)) {
    return;
  }

  const analysis = analyzeCodexArgs(codexArgs);
  const threadId = resolveResumeThreadId(account.home, analysis);
  if (!threadId) {
    return;
  }

  let result;
  try {
    result = await appServerRequest(account.home, "thread/goal/get", { threadId });
  } catch (error) {
    console.error(`[cx-auto] goal status check failed: ${error.message}`);
    return;
  }

  const goal = result?.goal || null;
  if (!goal || !shouldResumeGoalStatus(goal.status)) {
    return;
  }

  try {
    await appServerRequest(account.home, "thread/goal/set", { threadId, status: "active" });
    console.error(`[cx-auto] resumed ${goal.status} goal for ${threadId}.`);
  } catch (error) {
    console.error(`[cx-auto] goal resume failed: ${error.message}`);
  }
}

function retryPlanAfterRateLimit(previousArgs, accountHome, options = {}) {
  const analysis = analyzeCodexArgs(previousArgs);
  const sessionState = latestSessionTurnState(accountHome, { ...options, assumeUsageLimited: true });

  if (!sessionState.file) {
    return { args: [...previousArgs], session: null };
  }

  const retryAnalysis = retryTargetFromSession(analysis, sessionState);
  const retrySession = retrySessionFromState(accountHome, sessionState);
  let prompt = null;
  if (sessionState.incomplete) {
    prompt = continuationPrompt;
    if (retryAnalysis.mode === "interactive" && process.env.CX_INTERACTIVE_AUTO_EXEC === "1") {
      return { args: execResumeArgsFromInteractiveAnalysis(retryAnalysis, prompt), session: retrySession };
    }
  } else if (!sessionState.completed && analysis.prompt) {
    if (analysis.mode === "interactive") {
      return { args: [...previousArgs], session: retrySession };
    }
    prompt = analysis.prompt;
  }

  return { args: resumeArgsFromAnalysis(retryAnalysis, prompt), session: retrySession };
}

function retryArgsAfterRateLimit(previousArgs, accountHome, options = {}) {
  return retryPlanAfterRateLimit(previousArgs, accountHome, options).args;
}

async function probeAccounts(excludedNames = new Set(), options = {}) {
  const activeNames = options.activeNames || getActiveAccountNames();
  const accounts = getDefaultAccounts().filter((account) => !excludedNames.has(account.name));
  const results = await Promise.all(accounts.map((account) => readRateLimits(account)));
  for (const result of results) {
    result.active = activeNames.has(result.account.name);
  }
  return results;
}

function describeSelection(result, prefix = "cx-auto") {
  const limit = result.limits;
  console.error(
    `[${prefix}] selected ${accountDisplayName(result.account)}: 5h used ${formatPercent(usedPercent(limit, "primary"))}, ` +
      `weekly used ${formatPercent(usedPercent(limit, "secondary"))}`,
  );
}

function shellQuote(value) {
  if (/^[A-Za-z0-9_./:=+-]+$/.test(value)) {
    return value;
  }
  return `'${value.replace(/'/g, "'\\''")}'`;
}

function installSignalForwarding() {
  for (const signal of ["SIGINT", "SIGTERM", "SIGHUP"]) {
    process.on(signal, () => {
      terminating = true;
      if (activeChild && !activeChild.killed) {
        activeChild.kill(signal);
      }
    });
  }
}

function restoreTerminal() {
  if (process.stdout.isTTY) {
    process.stdout.write("\x1b[?1049l\x1b[?25h\x1b[0m\n");
  }
}

function isUsageLimitLogLine(line) {
  const trimmed = line.trim();
  if (!rateLimitTextPattern.test(trimmed)) {
    return false;
  }
  if (trimmed.includes("ToolCall:") || trimmed.includes("codex_core::stream_events_utils")) {
    return false;
  }
  if (nonAccountRateLimitPattern.test(trimmed)) {
    return false;
  }
  if (rateLimitUiPattern.test(trimmed)) {
    return true;
  }
  if (turnErrorRateLimitPattern.test(trimmed)) {
    return true;
  }
  if (structuredGoalUsageLimitPattern.test(trimmed)) {
    return true;
  }
  if (turnErrorHttpRateLimitPattern.test(trimmed)) {
    return true;
  }
  return logLevelLinePattern.test(trimmed) && rateLimitReasonPattern.test(trimmed);
}

function logChunkHasUsageLimit(chunk) {
  return chunk.split(/\r?\n/).some(isUsageLimitLogLine);
}

function runCodex(account, commandArgs) {
  return new Promise((resolve) => {
    const env = { ...process.env, CODEX_HOME: account.home };
    delete env.CODEX_THREAD_ID;

    const child = spawn("codex", commandArgs, { env, stdio: "inherit" });
    activeChild = child;
    child.on("exit", (code, signal) => {
      activeChild = null;
      resolve({ code, signal });
    });
  });
}

function runCodexMonitored(account, commandArgs, logDir) {
  return new Promise((resolve) => {
    const env = { ...process.env, CODEX_HOME: account.home };
    delete env.CODEX_THREAD_ID;

    const child = spawn("codex", commandArgs, { env, stdio: "inherit" });
    activeChild = child;

    const logFile = path.join(logDir, "codex-tui.log");
    let offset = 0;
    let pendingLogLine = "";
    let rateLimited = false;
    let settled = false;

    function finish(result) {
      if (settled) {
        return;
      }
      settled = true;
      clearInterval(timer);
      activeChild = null;
      resolve(result);
    }

    function scanLog() {
      try {
        const stat = fs.statSync(logFile);
        if (stat.size <= offset) {
          return;
        }
        const fd = fs.openSync(logFile, "r");
        try {
          while (offset < stat.size && !rateLimited) {
            const length = stat.size - offset;
            const buffer = Buffer.alloc(Math.min(length, 128 * 1024));
            const bytesRead = fs.readSync(fd, buffer, 0, buffer.length, offset);
            if (bytesRead <= 0) {
              break;
            }
            offset += bytesRead;

            const chunk = pendingLogLine + buffer.subarray(0, bytesRead).toString("utf8");
            const lines = chunk.split(/\r?\n/);
            pendingLogLine = chunk.endsWith("\n") || chunk.endsWith("\r") ? "" : lines.pop() || "";
            if (pendingLogLine.length > 8192) {
              pendingLogLine = pendingLogLine.slice(-8192);
            }

            if (lines.some(isUsageLimitLogLine) || isUsageLimitLogLine(pendingLogLine)) {
              rateLimited = true;
              console.error("\n[cx-auto] usage limit detected; switching account...");
              if (!child.killed) {
                child.kill("SIGTERM");
                setTimeout(() => {
                  if (!settled && !child.killed) {
                    child.kill("SIGKILL");
                  }
                }, 3000);
              }
            }
          }
        } finally {
          fs.closeSync(fd);
        }
      } catch {
        // The log file may not exist until Codex finishes initialization.
      }
    }

    const timer = setInterval(scanLog, 1000);
    child.on("exit", (code, signal) => {
      scanLog();
      finish({ code, signal, rateLimited });
    });
  });
}

async function runForced(options, codexArgs, account) {
  const commandArgs = [...baseGlobalArgs(options, codexArgs), ...codexArgs];
  if (options.dryRun) {
    console.error(`CODEX_HOME=${account.home} codex ${commandArgs.map(shellQuote).join(" ")}`);
    return 0;
  }

  await resumeGoalIfNeeded(account, codexArgs);
  const result = await runCodex(account, commandArgs);
  if (result.signal && terminating) {
    return 130;
  }
  return result.code ?? 1;
}

async function runAuto(options, initialArgs) {
  const accounts = getDefaultAccounts();
  const { autoMaxSwitches } = getRuntimeConfig();
  const exhausted = new Set();
  let codexArgs = [...initialArgs];
  let pendingRetrySession = null;
  let switches = 0;

  if (accounts.length < 1) {
    printNoAccountsConfigured();
    return 1;
  }

  if (options.status) {
    const results = await probeAccounts(exhausted);
    printStatus(results);
    return 0;
  }

  for (;;) {
    const results = await probeAccounts(exhausted);
    const selected = selectResult(results);

    if (!selected || !isUsable(selected)) {
      printStatus(results);
      console.error("[cx-auto] All candidate accounts are exhausted or unavailable.");
      return 1;
    }

    const logDir = fs.mkdtempSync(path.join(os.tmpdir(), `cx-auto-${safeAccountName(selected.account.name)}-`));
    fs.chmodSync(logDir, 0o700);
    const logConfigArg = `log_dir=${JSON.stringify(logDir)}`;
    const commandArgs = [...baseGlobalArgs(options, codexArgs, ["-c", logConfigArg]), ...codexArgs];

    describeSelection(selected);

    if (options.dryRun) {
      console.error(`CODEX_HOME=${selected.account.home} codex ${commandArgs.map(shellQuote).join(" ")}`);
      return 0;
    }

    ensureRetrySessionAvailable(pendingRetrySession, selected.account);
    await resumeGoalIfNeeded(selected.account, codexArgs);
    const runStartedAt = Date.now() - 2000;
    const result = await runCodexMonitored(selected.account, commandArgs, logDir);
    if (terminating) {
      return result.code ?? 130;
    }

    if (!result.rateLimited) {
      return result.code ?? 0;
    }

    restoreTerminal();
    exhausted.add(selected.account.name);
    switches += 1;

    if (switches > autoMaxSwitches) {
      console.error(`[cx-auto] Switch limit reached (${autoMaxSwitches}).`);
      return 1;
    }

    const retryPlan = retryPlanAfterRateLimit(codexArgs, selected.account.home, { minMtimeMs: runStartedAt });
    codexArgs = retryPlan.args;
    pendingRetrySession = retryPlan.session;
  }
}

async function main() {
  installSignalForwarding();

  const { options, codexArgs } = parseArgs(process.argv.slice(2));
  const accounts = getDefaultAccounts();
  const forced = options.account
    ? accounts.find((account) => accountMatches(account, options.account, accounts))
    : null;

  if (options.accountExplicit && !forced) {
    if (accounts.length < 1) {
      printNoAccountsConfigured();
    } else {
      console.error(`[cx] Unknown account: ${options.account}`);
      console.error(`[cx] Available selectors: ${accountSelectorHint(accounts)}`);
    }
    process.exit(2);
  }

  const code = options.accountExplicit ? await runForced(options, codexArgs, forced) : await runAuto(options, codexArgs);
  process.exit(code);
}

if (require.main === module) {
  main().catch((error) => {
    console.error(`[cx] ${error.exitCode ? error.message : error.stack || error.message}`);
    process.exit(error.exitCode || 1);
  });
}

