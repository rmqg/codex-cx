#!/usr/bin/env node
"use strict";

const { spawn } = require("child_process");
const fs = require("fs");
const os = require("os");
const path = require("path");

const home = os.homedir();
const defaultAccounts = [
  { name: "account1", home: path.join(home, ".codex-account1") },
  { name: "account2", home: path.join(home, ".codex-account2") },
  { name: "account3", home: path.join(home, ".codex-account3") },
];

const timeoutMs = Number(process.env.CX_LIMIT_TIMEOUT_MS || 15000);
const autoMaxSwitches = Number(process.env.CX_AUTO_MAX_SWITCHES || 5);
const weeklySimilarDelta = 5;
const primarySimilarDelta = 20;
const rateLimitPattern = /Turn error:.*(?:usage limit|rate limit|limit reached|429)|You've hit your usage limit/i;

let activeChild = null;
let terminating = false;

function usage() {
  console.log(`Usage:
  cx [codex args...]                         Auto-select account and auto-switch on limits.
  cx exec "prompt"                           Auto-select account and auto-switch on limits.
  cx auto [codex args...]                    Same as cx without --account.
  cx --account 2 [codex args...]             Run only with account2.
  cx status
  cx --dry-run [codex args...]
  cx --no-bypass [codex args...]

Environment:
  CX_ACCOUNT=1|2|3|account1|account2|account3   Same as --account.
  CX_NO_BYPASS=1                                Do not add the bypass flag.
  CX_LIMIT_TIMEOUT_MS=15000                     Rate-limit probe timeout.
  CX_AUTO_MAX_SWITCHES=5                        Max automatic account switches per run.
`);
}

function parseArgs(argv) {
  const codexArgs = [];
  const options = {
    auto: false,
    status: false,
    dryRun: false,
    noBypass: process.env.CX_NO_BYPASS === "1",
    account: process.env.CX_ACCOUNT || null,
    accountExplicit: Boolean(process.env.CX_ACCOUNT),
  };

  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === "-h" || arg === "--help") {
      usage();
      process.exit(0);
    }
    if (arg === "auto" || arg === "--auto" || arg === "--auto-switch") {
      options.auto = true;
      continue;
    }
    if (arg === "status" || arg === "--status") {
      options.status = true;
      continue;
    }
    if (arg === "--dry-run") {
      options.dryRun = true;
      continue;
    }
    if (arg === "--no-bypass") {
      options.noBypass = true;
      continue;
    }
    if (arg === "--account") {
      if (!argv[i + 1] || argv[i + 1].startsWith("-")) {
        const error = new Error("--account requires 1, 2, 3, account1, account2, or account3");
        error.exitCode = 2;
        throw error;
      }
      options.account = argv[i + 1];
      options.accountExplicit = true;
      i += 1;
      continue;
    }
    if (arg.startsWith("--account=")) {
      options.account = arg.slice("--account=".length);
      options.accountExplicit = true;
      continue;
    }
    codexArgs.push(arg);
  }

  return { options, codexArgs };
}

function accountMatches(account, selector) {
  if (!selector) {
    return false;
  }
  const normalized = String(selector).trim().toLowerCase();
  return (
    normalized === account.name.toLowerCase() ||
    normalized === account.name.replace(/^account/, "") ||
    normalized === path.basename(account.home).replace(/^\.codex-account/, "")
  );
}

function readRateLimits(account) {
  return new Promise((resolve) => {
    const authPath = path.join(account.home, "auth.json");
    if (!fs.existsSync(authPath)) {
      resolve({ account, ok: false, error: `missing ${authPath}` });
      return;
    }

    const env = { ...process.env, CODEX_HOME: account.home };
    delete env.CODEX_THREAD_ID;

    const child = spawn("codex", ["app-server", "--listen", "stdio://"], {
      env,
      stdio: ["pipe", "pipe", "pipe"],
    });

    let buffer = "";
    let stderr = "";
    let settled = false;

    const timer = setTimeout(() => {
      finish({ account, ok: false, error: `timeout after ${timeoutMs}ms` });
    }, timeoutMs);

    function finish(result) {
      if (settled) {
        return;
      }
      settled = true;
      clearTimeout(timer);
      if (!child.killed) {
        child.kill("SIGTERM");
      }
      resolve(result);
    }

    function send(message) {
      child.stdin.write(`${JSON.stringify(message)}\n`);
    }

    child.on("error", (error) => finish({ account, ok: false, error: error.message }));
    child.stderr.on("data", (chunk) => {
      stderr += chunk.toString();
      if (stderr.length > 4000) {
        stderr = stderr.slice(-4000);
      }
    });
    child.on("exit", (code) => {
      if (!settled && code !== 0) {
        finish({ account, ok: false, error: stderr.trim() || `codex app-server exited ${code}` });
      }
    });
    child.stdout.on("data", (chunk) => {
      buffer += chunk.toString();

      for (;;) {
        const newline = buffer.indexOf("\n");
        if (newline < 0) {
          break;
        }

        const line = buffer.slice(0, newline).trim();
        buffer = buffer.slice(newline + 1);
        if (!line) {
          continue;
        }

        let message;
        try {
          message = JSON.parse(line);
        } catch (error) {
          finish({ account, ok: false, error: `invalid JSON-RPC response: ${error.message}` });
          return;
        }

        if (message.id === "init") {
          send({ id: "limits", method: "account/rateLimits/read", params: null });
          continue;
        }

        if (message.id === "limits") {
          if (message.error) {
            finish({ account, ok: false, error: message.error.message || "rate-limit read failed" });
          } else {
            finish({ account, ok: true, limits: extractCodexLimit(message.result) });
          }
          return;
        }
      }
    });

    send({
      id: "init",
      method: "initialize",
      params: {
        clientInfo: { name: "cx", version: "0.2.0" },
        capabilities: { experimentalApi: true },
      },
    });
  });
}

function extractCodexLimit(result) {
  return (
    result?.rateLimitsByLimitId?.codex ||
    result?.rateLimits ||
    Object.values(result?.rateLimitsByLimitId || {})[0] ||
    null
  );
}

function usedPercent(limit, key) {
  const value = rawUsedPercent(limit, key);
  return Number.isFinite(value) ? value : 100;
}

function rawUsedPercent(limit, key) {
  const camelValue = limit?.[key]?.usedPercent;
  if (Number.isFinite(camelValue)) {
    return camelValue;
  }
  const snakeValue = limit?.[key]?.used_percent;
  return Number.isFinite(snakeValue) ? snakeValue : null;
}

function reached(limit) {
  if (!limit) {
    return "unknown";
  }
  return limit.rateLimitReachedType || limit.rate_limit_reached_type || "";
}

function limitExhaustedReason(result) {
  if (!result?.ok) {
    return result?.error || "probe failed";
  }
  if (!result.limits) {
    return "missing limits";
  }

  const reachedType = reached(result.limits);
  if (reachedType) {
    return reachedType;
  }

  const primary = rawUsedPercent(result.limits, "primary");
  if (Number.isFinite(primary) && primary >= 100) {
    return "5h>=100%";
  }

  const secondary = rawUsedPercent(result.limits, "secondary");
  if (Number.isFinite(secondary) && secondary >= 100) {
    return "weekly>=100%";
  }

  return "";
}

function isUsable(result) {
  return Boolean(result?.ok && result.limits && !limitExhaustedReason(result));
}

function getProcessActiveAccountNames() {
  const names = new Set();
  let pids;
  try {
    pids = fs.readdirSync("/proc").filter((entry) => /^\d+$/.test(entry));
  } catch {
    return names;
  }

  for (const pid of pids) {
    try {
      const cmdline = fs.readFileSync(`/proc/${pid}/cmdline`, "utf8").split("\0").filter(Boolean);
      const command = cmdline.join(" ");
      if (!command.includes("codex") || command.includes("app-server")) {
        continue;
      }
      const environ = fs.readFileSync(`/proc/${pid}/environ`, "utf8").split("\0").filter(Boolean);
      const codexHome = environ
        .map((entry) => entry.match(/^CODEX_HOME=(.*)$/))
        .find(Boolean)?.[1];
      if (!codexHome) {
        continue;
      }
      const account = defaultAccounts.find((candidate) => candidate.home === codexHome);
      if (account) {
        names.add(account.name);
      }
    } catch {
      // Processes can exit while we scan /proc.
    }
  }

  return names;
}

function getActiveAccountNames() {
  return getProcessActiveAccountNames();
}

function compareAccountResults(a, b) {
  const aUsable = isUsable(a);
  const bUsable = isUsable(b);
  if (aUsable !== bUsable) {
    return aUsable ? -1 : 1;
  }

  const aSecondary = usedPercent(a.limits, "secondary");
  const bSecondary = usedPercent(b.limits, "secondary");
  const secondaryDelta = aSecondary - bSecondary;
  if (Math.abs(secondaryDelta) > weeklySimilarDelta) {
    return secondaryDelta;
  }

  const aPrimary = usedPercent(a.limits, "primary");
  const bPrimary = usedPercent(b.limits, "primary");
  const primaryDelta = aPrimary - bPrimary;
  if (Math.abs(primaryDelta) > primarySimilarDelta) {
    return primaryDelta;
  }

  if (a.active !== b.active) {
    return a.active ? 1 : -1;
  }

  if (primaryDelta !== 0) {
    return primaryDelta;
  }

  if (secondaryDelta !== 0) {
    return secondaryDelta;
  }

  return a.account.name.localeCompare(b.account.name);
}

function formatPercent(value) {
  return `${Number.isFinite(value) ? value : 100}%`;
}

function printStatus(results) {
  console.error(
    `Selection rule: weekly delta > ${weeklySimilarDelta}% wins; within ${weeklySimilarDelta}% use 5h; ` +
      `5h delta <= ${primarySimilarDelta}% prefers inactive accounts; exhausted accounts are skipped.`,
  );
  console.error("Account   active   5h used   weekly used   reached   home");
  for (const result of results.slice().sort(compareAccountResults)) {
    const limit = result.limits;
    const active = result.active ? "yes" : "-";
    const primary = result.ok ? formatPercent(usedPercent(limit, "primary")) : "ERR";
    const secondary = result.ok ? formatPercent(usedPercent(limit, "secondary")) : "ERR";
    const hit = limitExhaustedReason(result) || "-";
    console.error(
      `${result.account.name.padEnd(9)} ${active.padEnd(8)} ${primary.padEnd(9)} ${secondary.padEnd(13)} ${String(hit).padEnd(9)} ${result.account.home}`,
    );
  }
}

function hasSafetyOverride(args) {
  return args.some((arg) =>
    arg === "--dangerously-bypass-approvals-and-sandbox" ||
    arg === "--sandbox" ||
    arg.startsWith("--sandbox=") ||
    arg === "--approval-policy" ||
    arg.startsWith("--approval-policy=") ||
    arg === "-s" ||
    arg === "-a"
  );
}

function baseGlobalArgs(options, codexArgs, extraGlobalArgs = []) {
  const globalArgs = [];
  if (!options.noBypass && !hasSafetyOverride(codexArgs)) {
    globalArgs.push("--dangerously-bypass-approvals-and-sandbox");
  }
  return [...globalArgs, ...extraGlobalArgs];
}

function selectResult(results) {
  return results.slice().sort(compareAccountResults).find(isUsable) || null;
}

async function probeAccounts(excludedNames = new Set(), options = {}) {
  const activeNames = options.activeNames || getActiveAccountNames();
  const accounts = defaultAccounts.filter((account) => !excludedNames.has(account.name));
  const results = await Promise.all(accounts.map(readRateLimits));
  for (const result of results) {
    result.active = activeNames.has(result.account.name);
  }
  return results;
}

function describeSelection(result, prefix = "cx-auto") {
  const limit = result.limits;
  console.error(
    `[${prefix}] selected ${result.account.name}: 5h used ${formatPercent(usedPercent(limit, "primary"))}, ` +
      `weekly used ${formatPercent(usedPercent(limit, "secondary"))}`,
  );
}

function shellQuote(value) {
  if (/^[A-Za-z0-9_./:=+-]+$/.test(value)) {
    return value;
  }
  return `'${value.replace(/'/g, "'\\''")}'`;
}

function installSignalForwarding() {
  for (const signal of ["SIGINT", "SIGTERM", "SIGHUP"]) {
    process.on(signal, () => {
      terminating = true;
      if (activeChild && !activeChild.killed) {
        activeChild.kill(signal);
      }
    });
  }
}

function restoreTerminal() {
  if (process.stdout.isTTY) {
    process.stdout.write("\x1b[?1049l\x1b[?25h\x1b[0m\n");
  }
}

function runCodex(account, commandArgs) {
  return new Promise((resolve) => {
    const env = { ...process.env, CODEX_HOME: account.home };
    delete env.CODEX_THREAD_ID;

    const child = spawn("codex", commandArgs, { env, stdio: "inherit" });
    activeChild = child;
    child.on("exit", (code, signal) => {
      activeChild = null;
      resolve({ code, signal });
    });
  });
}

function runCodexMonitored(account, commandArgs, logDir) {
  return new Promise((resolve) => {
    const env = { ...process.env, CODEX_HOME: account.home };
    delete env.CODEX_THREAD_ID;

    const child = spawn("codex", commandArgs, { env, stdio: "inherit" });
    activeChild = child;

    const logFile = path.join(logDir, "codex-tui.log");
    let offset = 0;
    let rateLimited = false;
    let settled = false;

    function finish(result) {
      if (settled) {
        return;
      }
      settled = true;
      clearInterval(timer);
      activeChild = null;
      resolve(result);
    }

    function scanLog() {
      try {
        const stat = fs.statSync(logFile);
        if (stat.size <= offset) {
          return;
        }
        const length = stat.size - offset;
        const fd = fs.openSync(logFile, "r");
        const buffer = Buffer.alloc(Math.min(length, 128 * 1024));
        fs.readSync(fd, buffer, 0, buffer.length, offset);
        fs.closeSync(fd);
        offset = stat.size;

        const chunk = buffer.toString("utf8");
        if (rateLimitPattern.test(chunk)) {
          rateLimited = true;
          console.error("\n[cx-auto] usage limit detected; switching account...");
          if (!child.killed) {
            child.kill("SIGTERM");
            setTimeout(() => {
              if (!settled && !child.killed) {
                child.kill("SIGKILL");
              }
            }, 3000);
          }
        }
      } catch {
        // The log file may not exist until Codex finishes initialization.
      }
    }

    const timer = setInterval(scanLog, 1000);
    child.on("exit", (code, signal) => {
      scanLog();
      finish({ code, signal, rateLimited });
    });
  });
}

async function runForced(options, codexArgs, account) {
  const commandArgs = [...baseGlobalArgs(options, codexArgs), ...codexArgs];
  if (options.dryRun) {
    console.error(`CODEX_HOME=${account.home} codex ${commandArgs.map(shellQuote).join(" ")}`);
    return 0;
  }

  const result = await runCodex(account, commandArgs);
  if (result.signal && terminating) {
    return 130;
  }
  return result.code ?? 1;
}

async function runAuto(options, initialArgs) {
  const exhausted = new Set();
  let codexArgs = [...initialArgs];
  let switches = 0;

  if (options.status) {
    const results = await probeAccounts(exhausted);
    printStatus(results);
    return 0;
  }

  for (;;) {
    const results = await probeAccounts(exhausted);
    const selected = selectResult(results);

    if (!selected || !isUsable(selected)) {
      printStatus(results);
      console.error("[cx-auto] All candidate accounts are exhausted or unavailable.");
      return 1;
    }

    const logDir = fs.mkdtempSync(path.join(os.tmpdir(), `cx-auto-${selected.account.name}-`));
    fs.chmodSync(logDir, 0o700);
    const logConfigArg = `log_dir=${JSON.stringify(logDir)}`;
    const commandArgs = [...baseGlobalArgs(options, codexArgs, ["-c", logConfigArg]), ...codexArgs];

    describeSelection(selected);

    if (options.dryRun) {
      console.error(`CODEX_HOME=${selected.account.home} codex ${commandArgs.map(shellQuote).join(" ")}`);
      return 0;
    }

    const result = await runCodexMonitored(selected.account, commandArgs, logDir);
    if (terminating) {
      return result.code ?? 130;
    }

    if (!result.rateLimited) {
      return result.code ?? 0;
    }

    restoreTerminal();
    exhausted.add(selected.account.name);
    switches += 1;

    if (switches > autoMaxSwitches) {
      console.error(`[cx-auto] Switch limit reached (${autoMaxSwitches}).`);
      return 1;
    }

    codexArgs = ["resume", "--last"];
  }
}

async function main() {
  installSignalForwarding();

  const { options, codexArgs } = parseArgs(process.argv.slice(2));
  const forced = options.account
    ? defaultAccounts.find((account) => accountMatches(account, options.account))
    : null;

  if (options.accountExplicit && !forced) {
    console.error(`[cx] Unknown account: ${options.account}`);
    process.exit(2);
  }

  const code = options.accountExplicit ? await runForced(options, codexArgs, forced) : await runAuto(options, codexArgs);
  process.exit(code);
}

if (require.main === module) {
  main().catch((error) => {
    console.error(`[cx] ${error.exitCode ? error.message : error.stack || error.message}`);
    process.exit(error.exitCode || 1);
  });
}

module.exports = {
  accountMatches,
  compareAccountResults,
  isUsable,
  limitExhaustedReason,
  reached,
  selectResult,
  usedPercent,
};
