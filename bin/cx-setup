#!/usr/bin/env node
"use strict";

const fs = require("fs");
const os = require("os");
const path = require("path");

const home = os.homedir();
const defaultSharedItems = [
  "sessions",
  "archived_sessions",
  "memories",
  "skills",
  "shell_snapshots",
  "cache",
  "generated_images",
  "history.jsonl",
  "models_cache.json",
];
const fullSharedItems = [
  ...defaultSharedItems,
  "log",
  "goals_1.sqlite",
  "goals_1.sqlite-shm",
  "goals_1.sqlite-wal",
  "logs_2.sqlite",
  "logs_2.sqlite-shm",
  "logs_2.sqlite-wal",
  "memories_1.sqlite",
  "memories_1.sqlite-shm",
  "memories_1.sqlite-wal",
  "state_5.sqlite",
  "state_5.sqlite-shm",
  "state_5.sqlite-wal",
];
const apiKeyModes = new Set(["prefer", "fallback"]);
const apiKeyCheckModes = new Set(["auto", "models", "responses", "chat"]);
const defaultApiKeyCheckTimeoutMs = 15000;

function usage() {
  console.log(`Usage:
  cx-setup [options]

Options:
  --accounts N          Create/link ~/.codex-account1..N.
  --homes LIST          Explicit account homes, comma-separated. Entries can be name=path or path.
  --add-api-key NAME    Create/update one API-key account. Default home: ~/.codex-account-NAME.
  --account-home DIR    Account home to use with --add-api-key.
  --api-key KEY         API key to write for --add-api-key.
  --api-key-env ENV     Read the API key for --add-api-key from ENV.
  --api-key-stdin       Read the API key for --add-api-key from stdin.
  --openai-base-url URL Write openai_base_url for the API-key account.
  --model MODEL         Write the default model for the API-key account.
  --api-key-check[=MODE]
                        Validate the OpenAI-compatible endpoint before writing auth.json.
                        MODE: auto, responses, chat, or models. Default: auto.
  --api-key-check-timeout-ms MS
                        Timeout for --api-key-check. Default: ${defaultApiKeyCheckTimeoutMs}.
  --list, --list-accounts
                        List selected/discovered account homes without changing files.
  --remove SELECTOR     Move a discovered/configured account home to a backup.
  --prune               With --accounts/--homes, move extra discovered homes to backups.
  --api-key-mode MODE   Persist local auto-selection mode: prefer or fallback.
  --home DIR            Shared Codex home. Default: ~/.codex.
  --prefix NAME         Account directory prefix. Default: ~/.codex-account.
  --full                Also share Codex state/log sqlite files.
  --migrate             Merge existing account data into shared home before linking.
  --force               Replace existing non-symlink account paths with backups before linking.
  --allow-active        Do not refuse active Codex account homes. Risky with --full.
  --dry-run             Print actions without changing files.

This never links auth.json. Log in once per account with:
  CODEX_HOME=~/.codex-accountN codex login

API-key example:
  printf '%s' "$OPENAI_API_KEY" | cx-setup --add-api-key free --api-key-stdin --openai-base-url https://proxy.example.com/v1 --model gpt-5.5 --api-key-check --migrate`);
}

function parseArgs(argv) {
  const options = {
    accounts: null,
    homes: null,
    sharedHome: path.join(home, ".codex"),
    prefix: path.join(home, ".codex-account"),
    full: false,
    migrate: false,
    force: false,
    allowActive: false,
    dryRun: false,
    addApiKey: null,
    accountHome: null,
    apiKey: null,
    apiKeyEnv: null,
    apiKeyStdin: false,
    openaiBaseUrl: null,
    model: null,
    apiKeyCheck: null,
    apiKeyCheckTimeoutMs: defaultApiKeyCheckTimeoutMs,
    list: false,
    remove: [],
    prune: false,
    apiKeyMode: null,
  };

  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === "-h" || arg === "--help") {
      usage();
      process.exit(0);
    }
    if (arg === "--full") {
      options.full = true;
      continue;
    }
    if (arg === "--migrate") {
      options.migrate = true;
      continue;
    }
    if (arg === "--force") {
      options.force = true;
      continue;
    }
    if (arg === "--allow-active") {
      options.allowActive = true;
      continue;
    }
    if (arg === "--dry-run") {
      options.dryRun = true;
      continue;
    }
    if (arg === "--api-key-stdin") {
      options.apiKeyStdin = true;
      continue;
    }
    if (arg === "--api-key-check" || arg === "--check-api-key" || arg === "--validate-api-key") {
      options.apiKeyCheck = "auto";
      continue;
    }
    if (arg.startsWith("--api-key-check=")) {
      options.apiKeyCheck = normalizeApiKeyCheckMode(arg.slice("--api-key-check=".length), "--api-key-check");
      continue;
    }
    if (arg.startsWith("--check-api-key=")) {
      options.apiKeyCheck = normalizeApiKeyCheckMode(arg.slice("--check-api-key=".length), "--check-api-key");
      continue;
    }
    if (arg.startsWith("--validate-api-key=")) {
      options.apiKeyCheck = normalizeApiKeyCheckMode(arg.slice("--validate-api-key=".length), "--validate-api-key");
      continue;
    }
    if (arg === "--prune") {
      options.prune = true;
      continue;
    }
    if (arg === "--list" || arg === "--list-accounts") {
      options.list = true;
      continue;
    }
    if (arg === "--accounts") {
      options.accounts = parsePositiveInteger(requiredValue(argv, ++i, arg), arg);
      continue;
    }
    if (arg.startsWith("--accounts=")) {
      options.accounts = parsePositiveInteger(arg.slice("--accounts=".length), "--accounts");
      continue;
    }
    if (arg === "--homes") {
      options.homes = parseHomes(requiredValue(argv, ++i, arg));
      continue;
    }
    if (arg.startsWith("--homes=")) {
      options.homes = parseHomes(arg.slice("--homes=".length));
      continue;
    }
    if (arg === "--add-api-key") {
      options.addApiKey = parseAccountName(requiredValue(argv, ++i, arg), arg);
      continue;
    }
    if (arg.startsWith("--add-api-key=")) {
      options.addApiKey = parseAccountName(arg.slice("--add-api-key=".length), "--add-api-key");
      continue;
    }
    if (arg === "--account-home") {
      options.accountHome = expandHomePath(requiredValue(argv, ++i, arg));
      continue;
    }
    if (arg.startsWith("--account-home=")) {
      options.accountHome = expandHomePath(arg.slice("--account-home=".length));
      continue;
    }
    if (arg === "--api-key") {
      options.apiKey = requiredValue(argv, ++i, arg);
      continue;
    }
    if (arg.startsWith("--api-key=")) {
      options.apiKey = arg.slice("--api-key=".length);
      continue;
    }
    if (arg === "--api-key-env") {
      options.apiKeyEnv = requiredValue(argv, ++i, arg);
      continue;
    }
    if (arg.startsWith("--api-key-env=")) {
      options.apiKeyEnv = arg.slice("--api-key-env=".length);
      continue;
    }
    if (arg === "--openai-base-url" || arg === "--base-url") {
      options.openaiBaseUrl = normalizeOpenAiBaseUrl(requiredValue(argv, ++i, arg), arg);
      continue;
    }
    if (arg.startsWith("--openai-base-url=")) {
      options.openaiBaseUrl = normalizeOpenAiBaseUrl(arg.slice("--openai-base-url=".length), "--openai-base-url");
      continue;
    }
    if (arg.startsWith("--base-url=")) {
      options.openaiBaseUrl = normalizeOpenAiBaseUrl(arg.slice("--base-url=".length), "--base-url");
      continue;
    }
    if (arg === "--model") {
      options.model = requiredValue(argv, ++i, arg);
      continue;
    }
    if (arg.startsWith("--model=")) {
      options.model = arg.slice("--model=".length);
      continue;
    }
    if (arg === "--api-key-check-mode") {
      options.apiKeyCheck = normalizeApiKeyCheckMode(requiredValue(argv, ++i, arg), arg);
      continue;
    }
    if (arg.startsWith("--api-key-check-mode=")) {
      options.apiKeyCheck = normalizeApiKeyCheckMode(arg.slice("--api-key-check-mode=".length), "--api-key-check-mode");
      continue;
    }
    if (arg === "--api-key-check-timeout-ms" || arg === "--api-key-timeout-ms") {
      options.apiKeyCheckTimeoutMs = parsePositiveInteger(requiredValue(argv, ++i, arg), arg);
      continue;
    }
    if (arg.startsWith("--api-key-check-timeout-ms=")) {
      options.apiKeyCheckTimeoutMs = parsePositiveInteger(
        arg.slice("--api-key-check-timeout-ms=".length),
        "--api-key-check-timeout-ms",
      );
      continue;
    }
    if (arg.startsWith("--api-key-timeout-ms=")) {
      options.apiKeyCheckTimeoutMs = parsePositiveInteger(arg.slice("--api-key-timeout-ms=".length), "--api-key-timeout-ms");
      continue;
    }
    if (arg === "--remove") {
      options.remove.push(requiredValue(argv, ++i, arg));
      continue;
    }
    if (arg.startsWith("--remove=")) {
      options.remove.push(arg.slice("--remove=".length));
      continue;
    }
    if (arg === "--api-key-mode") {
      options.apiKeyMode = normalizeApiKeyMode(requiredValue(argv, ++i, arg), arg);
      continue;
    }
    if (arg.startsWith("--api-key-mode=")) {
      options.apiKeyMode = normalizeApiKeyMode(arg.slice("--api-key-mode=".length), "--api-key-mode");
      continue;
    }
    if (arg === "--home") {
      options.sharedHome = expandHomePath(requiredValue(argv, ++i, arg));
      continue;
    }
    if (arg.startsWith("--home=")) {
      options.sharedHome = expandHomePath(arg.slice("--home=".length));
      continue;
    }
    if (arg === "--prefix") {
      options.prefix = expandHomePath(requiredValue(argv, ++i, arg));
      continue;
    }
    if (arg.startsWith("--prefix=")) {
      options.prefix = expandHomePath(arg.slice("--prefix=".length));
      continue;
    }
    throw new Error(`Unknown option: ${arg}`);
  }

  if (options.apiKeyCheck && !options.addApiKey) {
    throw new Error("--api-key-check requires --add-api-key");
  }

  return options;
}

function requiredValue(argv, index, flag) {
  const value = argv[index];
  if (!value || value.startsWith("-")) {
    throw new Error(`${flag} requires a value`);
  }
  return value;
}

function parsePositiveInteger(value, label) {
  const parsed = Number(value);
  if (!Number.isInteger(parsed) || parsed < 1) {
    throw new Error(`${label} must be a positive integer`);
  }
  return parsed;
}

function parseAccountName(value, label) {
  const name = String(value || "").trim();
  if (!name) {
    throw new Error(`${label} requires a non-empty account name`);
  }
  if (!/^[A-Za-z0-9_.-]+$/.test(name)) {
    throw new Error(`${label} account name can only contain letters, numbers, dots, underscores, and hyphens`);
  }
  if (name === "." || name === "..") {
    throw new Error(`${label} account name must not be ${name}`);
  }
  return name;
}

function normalizeOpenAiBaseUrl(value, label = "--openai-base-url") {
  const raw = String(value || "").trim();
  if (!raw) {
    throw new Error(`${label} requires a non-empty URL`);
  }

  let parsed;
  try {
    parsed = new URL(raw);
  } catch {
    throw new Error(`${label} must be a valid http(s) URL`);
  }

  if (parsed.protocol !== "https:" && parsed.protocol !== "http:") {
    throw new Error(`${label} must use http or https`);
  }
  if (!parsed.hostname) {
    throw new Error(`${label} must include a host`);
  }
  if (parsed.search || parsed.hash) {
    throw new Error(`${label} must not include query parameters or a fragment`);
  }

  return parsed.toString().replace(/\/+$/, "");
}

function expandHomePath(value) {
  if (value === "~") {
    return home;
  }
  if (value.startsWith("~/")) {
    return path.join(home, value.slice(2));
  }
  return path.resolve(value);
}

function defaultApiKeyAccountHome(name) {
  return path.join(home, `.codex-account-${name}`);
}

function isPathSelector(selector) {
  const value = String(selector || "").trim();
  return value.includes("/") || value === "." || value === ".." || value.startsWith("~");
}

function naturalAccountSort(a, b) {
  const left = a.suffix.match(/^\d+$/) ? Number(a.suffix) : null;
  const right = b.suffix.match(/^\d+$/) ? Number(b.suffix) : null;
  if (left !== null && right !== null) {
    return left - right;
  }
  if (left !== null) {
    return -1;
  }
  if (right !== null) {
    return 1;
  }
  return a.name.localeCompare(b.name);
}

function discoveredAccountName(fileName, index) {
  const suffix = fileName.slice(".codex-account".length);
  if (/^\d+$/.test(suffix)) {
    return `account${suffix}`;
  }
  const trimmed = suffix.replace(/^-+/, "");
  return trimmed || `account${index + 1}`;
}

function discoverAccountHomes() {
  let entries;
  try {
    entries = fs.readdirSync(home, { withFileTypes: true });
  } catch {
    return [];
  }

  return entries
    .filter((entry) =>
      entry.name.startsWith(".codex-account") &&
      entry.name !== ".codex-account" &&
      !entry.name.includes(".cx-backup-")
    )
    .map((entry, index) => ({
      dirent: entry,
      name: discoveredAccountName(entry.name, index),
      suffix: entry.name.slice(".codex-account".length),
      home: path.join(home, entry.name),
    }))
    .filter((account) => {
      if (account.dirent.isDirectory() || account.dirent.isSymbolicLink()) {
        return true;
      }
      try {
        return fs.statSync(account.home).isDirectory();
      } catch {
        return false;
      }
    })
    .sort(naturalAccountSort)
    .map(({ name, home: accountHome }) => ({ name, home: accountHome }));
}

function parseHomes(value) {
  const homes = value
    .split(",")
    .map((entry) => entry.trim())
    .filter(Boolean)
    .map((entry, index) => {
      const equals = entry.indexOf("=");
      if (equals >= 0) {
        const accountHome = entry.slice(equals + 1).trim();
        if (!accountHome) {
          throw new Error("--homes entries must include a path");
        }
        return {
          name: entry.slice(0, equals).trim() || `account${index + 1}`,
          home: expandHomePath(accountHome),
        };
      }
      return { name: `account${index + 1}`, home: expandHomePath(entry) };
    });

  if (homes.length < 1) {
    throw new Error("--homes requires at least one account home");
  }
  return homes;
}

function accountHomes(options) {
  if (options.addApiKey && !options.homes && options.accounts === null) {
    return [{ name: options.addApiKey, home: options.accountHome || defaultApiKeyAccountHome(options.addApiKey) }];
  }
  if (options.homes) {
    return appendApiKeyHome(options, options.homes);
  }
  if (options.accounts === null) {
    return appendApiKeyHome(options, discoverAccountHomes());
  }
  return appendApiKeyHome(options, Array.from({ length: options.accounts }, (_, index) => ({
    name: `account${index + 1}`,
    home: `${options.prefix}${index + 1}`,
  })));
}

function appendApiKeyHome(options, accounts) {
  if (!options.addApiKey) {
    return accounts;
  }

  const accountHome = options.accountHome || defaultApiKeyAccountHome(options.addApiKey);
  const existing = accounts.find((account) => account.name.toLowerCase() === options.addApiKey.toLowerCase());
  if (existing) {
    return accounts.map((account) =>
      account === existing ? { ...account, home: options.accountHome ? accountHome : account.home } : account,
    );
  }
  return [...accounts, { name: options.addApiKey, home: accountHome }];
}

function validateAccounts(accounts, sharedHome) {
  const names = new Map();
  const homes = new Map();
  const normalizedSharedHome = path.resolve(sharedHome);

  return accounts.map((account) => {
    const name = String(account.name || "").trim();
    if (!name) {
      throw new Error("Account homes include an account without a name");
    }

    const normalizedName = name.toLowerCase();
    const normalizedHome = path.resolve(account.home);
    if (names.has(normalizedName)) {
      throw new Error(`Account homes include duplicate account name: ${name}`);
    }
    if (homes.has(normalizedHome)) {
      throw new Error(`Account homes include duplicate account home: ${normalizedHome}`);
    }
    if (normalizedHome === normalizedSharedHome) {
      throw new Error(`Account home must not be the shared home: ${normalizedHome}`);
    }

    names.set(normalizedName, account);
    homes.set(normalizedHome, account);
    return { ...account, name, home: normalizedHome };
  });
}

function mergeAccounts(...groups) {
  const merged = [];
  const homes = new Set();
  for (const group of groups) {
    for (const account of group) {
      const normalizedHome = path.resolve(account.home);
      if (homes.has(normalizedHome)) {
        continue;
      }
      homes.add(normalizedHome);
      merged.push({ ...account, home: normalizedHome });
    }
  }
  return merged;
}

function activeCodexHomes() {
  const active = new Set();
  let pids;
  try {
    pids = fs.readdirSync("/proc").filter((entry) => /^\d+$/.test(entry));
  } catch {
    return active;
  }

  for (const pid of pids) {
    try {
      const cmdline = fs.readFileSync(`/proc/${pid}/cmdline`, "utf8").split("\0").filter(Boolean);
      const command = cmdline.join(" ");
      if (!command.includes("codex") || command.includes("app-server")) {
        continue;
      }
      const codexHome = fs
        .readFileSync(`/proc/${pid}/environ`, "utf8")
        .split("\0")
        .map((entry) => entry.match(/^CODEX_HOME=(.*)$/))
        .find(Boolean)?.[1];
      if (codexHome) {
        active.add(path.resolve(codexHome));
      }
    } catch {
      // Processes can exit while we scan /proc.
    }
  }

  return active;
}

function backupPath(target) {
  const stamp = new Date().toISOString().replace(/[-:T.Z]/g, "").slice(0, 14);
  return `${target}.cx-backup-${stamp}-${process.pid}`;
}

function localConfigPath() {
  const base = process.env.XDG_CONFIG_HOME ? expandHomePath(process.env.XDG_CONFIG_HOME) : path.join(home, ".config");
  return path.join(base, "codex-cx", "config.json");
}

function readLocalConfig() {
  try {
    return JSON.parse(fs.readFileSync(localConfigPath(), "utf8"));
  } catch {
    return {};
  }
}

function writeLocalConfigPatch(values, options) {
  const target = localConfigPath();
  const next = { ...readLocalConfig(), ...values };
  if (options.dryRun) {
    console.log(`[dry-run] write ${target}`);
    return;
  }
  fs.mkdirSync(path.dirname(target), { recursive: true });
  fs.writeFileSync(target, `${JSON.stringify(next, null, 2)}\n`, { mode: 0o600 });
  console.log(`wrote ${target}`);
}

function normalizeApiKeyMode(value, label = "api key mode") {
  const normalized = String(value || "").trim().toLowerCase().replace(/_/g, "-");
  if (["prefer", "first", "api-key-first", "apikey-first", "apikey", "api-key"].includes(normalized)) {
    return "prefer";
  }
  if (["fallback", "account-first", "after-limit", "limit-fallback", "limit-exhausted"].includes(normalized)) {
    return "fallback";
  }
  throw new Error(`${label} must be prefer or fallback`);
}

function normalizeApiKeyCheckMode(value, label = "--api-key-check") {
  const normalized = String(value || "").trim().toLowerCase().replace(/_/g, "-");
  if (["", "1", "true", "yes", "auto"].includes(normalized)) {
    return "auto";
  }
  if (["model", "models", "list", "list-models"].includes(normalized)) {
    return "models";
  }
  if (["response", "responses", "responses-api"].includes(normalized)) {
    return "responses";
  }
  if (["chat", "chat-completions", "completions"].includes(normalized)) {
    return "chat";
  }
  if (!apiKeyCheckModes.has(normalized)) {
    throw new Error(`${label} must be auto, responses, chat, or models`);
  }
  return normalized;
}

function ensureDir(dir, options) {
  if (options.dryRun) {
    console.log(`[dry-run] mkdir -p ${dir}`);
    return;
  }
  fs.mkdirSync(dir, { recursive: true });
}

function ensureParent(file, options) {
  ensureDir(path.dirname(file), options);
}

function isDirectory(target) {
  try {
    return fs.statSync(target).isDirectory();
  } catch {
    return false;
  }
}

function copyMerge(source, destination, options) {
  if (!fs.existsSync(source)) {
    return;
  }

  ensureParent(destination, options);
  const stat = fs.lstatSync(source);
  if (stat.isSymbolicLink()) {
    return;
  }
  if (stat.isDirectory()) {
    ensureDir(destination, options);
    for (const entry of fs.readdirSync(source)) {
      copyMerge(path.join(source, entry), path.join(destination, entry), options);
    }
    return;
  }
  if (!fs.existsSync(destination)) {
    if (options.dryRun) {
      console.log(`[dry-run] copy ${source} -> ${destination}`);
    } else {
      fs.copyFileSync(source, destination);
    }
  }
}

function removeForLink(target, options) {
  if (!fs.existsSync(target) && !fs.lstatSync(target, { throwIfNoEntry: false })) {
    return;
  }
  const backup = backupPath(target);
  if (options.dryRun) {
    console.log(`[dry-run] mv ${target} ${backup}`);
    return;
  }
  fs.renameSync(target, backup);
}

function removeAccountHome(account, options) {
  const existing = fs.lstatSync(account.home, { throwIfNoEntry: false });
  if (!existing) {
    console.log(`already absent ${account.home}`);
    return;
  }
  const backup = backupPath(account.home);
  if (options.dryRun) {
    console.log(`[dry-run] mv ${account.home} ${backup}`);
    return;
  }
  fs.renameSync(account.home, backup);
  console.log(`removed ${account.name}: ${account.home} -> ${backup}`);
}

function selectorMatches(account, selector, accounts) {
  const normalized = String(selector || "").trim().toLowerCase();
  const normalizedPath = isPathSelector(selector) ? path.resolve(expandHomePath(String(selector).trim())) : null;
  const index = accounts.indexOf(account);
  return (
    normalized === String(index + 1) ||
    normalized === account.name.toLowerCase() ||
    (normalizedPath && normalizedPath === path.resolve(account.home)) ||
    normalized === path.basename(account.home).toLowerCase() ||
    normalized === path.basename(account.home).replace(/^\.codex-account-?/, "").toLowerCase()
  );
}

function findRemoveTarget(selector, accounts) {
  const matches = accounts.filter((candidate) => selectorMatches(candidate, selector, accounts));
  if (matches.length === 0) {
    throw new Error(`Unknown account to remove: ${selector}. Run cx-setup --list to see removable accounts.`);
  }
  const uniqueHomes = [...new Map(matches.map((account) => [path.resolve(account.home), account])).values()];
  if (uniqueHomes.length > 1) {
    throw new Error(
      `Ambiguous account selector for --remove: ${selector}. Matches: ` +
        uniqueHomes.map((account) => `${account.name}=${account.home}`).join(", "),
    );
  }
  return uniqueHomes[0];
}

function readAccountAuth(account) {
  const authPath = path.join(account.home, "auth.json");
  if (!fs.existsSync(authPath)) {
    return { status: "missing" };
  }
  try {
    return { status: "ok", auth: JSON.parse(fs.readFileSync(authPath, "utf8")) };
  } catch {
    return { status: "invalid" };
  }
}

function accountAuthLabel(account) {
  const result = readAccountAuth(account);
  if (result.status !== "ok") {
    return result.status;
  }
  if (result.auth?.auth_mode === "apikey" || result.auth?.OPENAI_API_KEY) {
    return "api-key";
  }
  return result.auth?.auth_mode || "account";
}

function linkedSharedItemCount(accountHome, sharedHome, items) {
  let count = 0;
  for (const item of items) {
    const target = path.join(accountHome, item);
    const source = path.join(sharedHome, item);
    const existing = fs.lstatSync(target, { throwIfNoEntry: false });
    if (!existing?.isSymbolicLink()) {
      continue;
    }
    if (path.resolve(path.dirname(target), fs.readlinkSync(target)) === source) {
      count += 1;
    }
  }
  return count;
}

function printAccountList(accounts, sharedHome, options) {
  const items = options.full ? fullSharedItems : defaultSharedItems;
  const activeHomes = activeCodexHomes();
  const normalizedSharedHome = path.resolve(sharedHome);
  if (accounts.length < 1) {
    console.log("No Codex account homes found.");
    return;
  }

  console.log("Account   exists   active   auth      linked   home");
  for (const account of accounts) {
    const exists = fs.lstatSync(account.home, { throwIfNoEntry: false }) ? "yes" : "-";
    const active = activeHomes.has(account.home) ? "yes" : "-";
    const auth = accountAuthLabel(account);
    const linked = `${linkedSharedItemCount(account.home, normalizedSharedHome, items)}/${items.length}`;
    console.log(
      `${account.name.padEnd(9)} ${exists.padEnd(8)} ${active.padEnd(8)} ${auth.padEnd(9)} ${linked.padEnd(8)} ${account.home}`,
    );
  }
}

function readApiKey(options) {
  if (Object.prototype.hasOwnProperty.call(options, "_apiKeyValue")) {
    return options._apiKeyValue;
  }

  const sources = [options.apiKey !== null, Boolean(options.apiKeyEnv), options.apiKeyStdin].filter(Boolean).length;
  if (sources !== 1) {
    throw new Error("--add-api-key requires exactly one of --api-key, --api-key-env, or --api-key-stdin");
  }
  let value;
  if (options.apiKey !== null) {
    value = String(options.apiKey).trim();
  } else if (options.apiKeyEnv) {
    value = String(process.env[options.apiKeyEnv] || "").trim();
  } else {
    value = fs.readFileSync(0, "utf8").trim();
  }
  options._apiKeyValue = value;
  return value;
}

function apiKeyCheckUrl(baseUrl, suffix) {
  return `${normalizeOpenAiBaseUrl(baseUrl)}${suffix}`;
}

function responseTextSnippet(text) {
  const trimmed = String(text || "").replace(/\s+/g, " ").trim();
  return trimmed.length > 240 ? `${trimmed.slice(0, 240)}...` : trimmed;
}

function extractResponseText(payload) {
  if (typeof payload?.output_text === "string") {
    return payload.output_text;
  }
  const output = Array.isArray(payload?.output) ? payload.output : [];
  return output
    .flatMap((item) => (Array.isArray(item?.content) ? item.content : []))
    .map((item) => item?.text || "")
    .join("");
}

async function readJsonResponse(response, label) {
  const text = await response.text();
  let payload = null;
  try {
    payload = text ? JSON.parse(text) : null;
  } catch {
    // Keep the text snippet for the error message below.
  }

  if (!response.ok) {
    const message = payload?.error?.message || payload?.message || responseTextSnippet(text);
    throw new Error(`${label} returned HTTP ${response.status}${message ? `: ${message}` : ""}`);
  }
  if (!payload || typeof payload !== "object") {
    throw new Error(`${label} returned non-JSON response${text ? `: ${responseTextSnippet(text)}` : ""}`);
  }
  if (payload.error) {
    const message = payload.error.message || payload.message || responseTextSnippet(JSON.stringify(payload.error));
    throw new Error(`${label} returned error${message ? `: ${message}` : ""}`);
  }
  return payload;
}

async function fetchJson(url, init, options) {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), options.apiKeyCheckTimeoutMs);
  const label = `${init.method || "GET"} ${url}`;
  try {
    const response = await fetch(url, { ...init, signal: controller.signal });
    return await readJsonResponse(response, label);
  } catch (error) {
    if (error?.name === "AbortError") {
      throw new Error(`${label} timed out after ${options.apiKeyCheckTimeoutMs}ms`);
    }
    if (error?.message?.startsWith(label)) {
      throw error;
    }
    const reason = error?.cause?.message || error?.message || String(error);
    throw new Error(`${label} failed: ${reason}`);
  } finally {
    clearTimeout(timeout);
  }
}

function apiKeyCheckHeaders(apiKey, extra = {}) {
  return {
    authorization: `Bearer ${apiKey}`,
    ...extra,
  };
}

async function checkApiKeyModels(apiKey, options) {
  const url = apiKeyCheckUrl(options.openaiBaseUrl, "/models");
  const payload = await fetchJson(url, { method: "GET", headers: apiKeyCheckHeaders(apiKey) }, options);
  if (!Array.isArray(payload.data)) {
    throw new Error(`GET ${url} did not return a model list`);
  }
  return { mode: "models", count: payload.data.length };
}

async function checkApiKeyResponses(apiKey, options) {
  if (!options.model) {
    throw new Error("--api-key-check=responses requires --model");
  }
  const url = apiKeyCheckUrl(options.openaiBaseUrl, "/responses");
  const payload = await fetchJson(
    url,
    {
      method: "POST",
      headers: apiKeyCheckHeaders(apiKey, { "content-type": "application/json" }),
      body: JSON.stringify({
        model: options.model,
        input: "Reply exactly: ping",
        max_output_tokens: 16,
      }),
    },
    options,
  );
  const text = extractResponseText(payload);
  return { mode: "responses", model: payload.model || options.model, text };
}

async function checkApiKeyChat(apiKey, options) {
  if (!options.model) {
    throw new Error("--api-key-check=chat requires --model");
  }
  const url = apiKeyCheckUrl(options.openaiBaseUrl, "/chat/completions");
  const payload = await fetchJson(
    url,
    {
      method: "POST",
      headers: apiKeyCheckHeaders(apiKey, { "content-type": "application/json" }),
      body: JSON.stringify({
        model: options.model,
        messages: [{ role: "user", content: "Reply exactly: ping" }],
        max_tokens: 16,
      }),
    },
    options,
  );
  return { mode: "chat", model: payload.model || options.model, text: payload.choices?.[0]?.message?.content || "" };
}

async function checkApiKeyEndpoint(apiKey, options) {
  if (!options.apiKeyCheck) {
    return;
  }
  if (!options.openaiBaseUrl) {
    throw new Error("--api-key-check requires --openai-base-url");
  }
  if (options.dryRun) {
    console.log(`[dry-run] check API key endpoint ${options.openaiBaseUrl} (${options.apiKeyCheck})`);
    return;
  }

  if (options.apiKeyCheck === "models" || (options.apiKeyCheck === "auto" && !options.model)) {
    const models = await checkApiKeyModels(apiKey, options);
    console.log(`checked API-key endpoint: ${options.openaiBaseUrl} returned ${models.count} models`);
    return;
  }

  const result =
    options.apiKeyCheck === "chat"
      ? await checkApiKeyChat(apiKey, options)
      : await checkApiKeyResponses(apiKey, options);
  const reply = result.text ? `, reply ${JSON.stringify(responseTextSnippet(result.text))}` : "";
  console.log(`checked API-key endpoint: ${result.mode} ok for ${result.model}${reply}`);
}

async function preflightApiKeyAccount(account, options) {
  if (options._apiKeyPreflight) {
    return;
  }

  const apiKey = readApiKey(options);
  if (!apiKey) {
    throw new Error("API key is empty");
  }

  const authPath = path.join(account.home, "auth.json");
  const existingAuth = fs.lstatSync(authPath, { throwIfNoEntry: false });
  if (existingAuth && !options.force) {
    throw new Error(`${authPath} exists; use --force to replace it`);
  }

  await checkApiKeyEndpoint(apiKey, options);
  options._apiKeyPreflight = true;
}

function tomlString(value) {
  return JSON.stringify(String(value));
}

function firstTableLine(lines) {
  const index = lines.findIndex((line) => /^\s*\[/.test(line));
  return index >= 0 ? index : lines.length;
}

function upsertTopLevelTomlStrings(file, values, options) {
  const existing = fs.existsSync(file) ? fs.readFileSync(file, "utf8") : "";
  const lines = existing ? existing.replace(/\r\n/g, "\n").split("\n") : [];
  if (lines.length > 0 && lines.at(-1) === "") {
    lines.pop();
  }

  const pending = new Map(Object.entries(values).filter(([, value]) => value !== null && value !== undefined));
  const tableIndex = firstTableLine(lines);
  for (let index = 0; index < tableIndex; index += 1) {
    const match = lines[index].match(/^\s*([A-Za-z0-9_-]+)\s*=/);
    if (!match || !pending.has(match[1])) {
      continue;
    }
    lines[index] = `${match[1]} = ${tomlString(pending.get(match[1]))}`;
    pending.delete(match[1]);
  }

  if (pending.size > 0) {
    const insert = [...pending.entries()].map(([key, value]) => `${key} = ${tomlString(value)}`);
    lines.splice(tableIndex, 0, ...insert, ...(tableIndex === 0 && lines.length > 0 ? [""] : []));
  }

  if (options.dryRun) {
    console.log(`[dry-run] write ${file}`);
    return;
  }
  ensureParent(file, options);
  fs.writeFileSync(file, `${lines.join("\n")}\n`, { mode: 0o600 });
}

async function writeApiKeyAccount(account, options) {
  await preflightApiKeyAccount(account, options);
  const apiKey = readApiKey(options);

  const authPath = path.join(account.home, "auth.json");

  const configValues = {
    cli_auth_credentials_store: "file",
    forced_login_method: "api",
  };
  if (options.model) {
    configValues.model = options.model;
  }
  if (options.openaiBaseUrl) {
    configValues.openai_base_url = options.openaiBaseUrl;
  }

  upsertTopLevelTomlStrings(path.join(account.home, "config.toml"), configValues, options);
  if (options.dryRun) {
    console.log(`[dry-run] write ${authPath}`);
  } else {
    ensureParent(authPath, options);
    fs.writeFileSync(
      authPath,
      `${JSON.stringify({ auth_mode: "apikey", OPENAI_API_KEY: apiKey }, null, 2)}\n`,
      { mode: 0o600 },
    );
  }
  console.log(`configured API-key account ${account.name} at ${account.home}`);
}

function linkItem(accountHome, sharedHome, item, options) {
  const source = path.join(sharedHome, item);
  const target = path.join(accountHome, item);

  ensureParent(source, options);
  if (item.endsWith("/") || isDirectory(target) || !path.extname(item)) {
    ensureDir(source, options);
  }

  const existing = fs.lstatSync(target, { throwIfNoEntry: false });
  if (existing?.isSymbolicLink()) {
    const current = fs.readlinkSync(target);
    if (path.resolve(path.dirname(target), current) === source) {
      console.log(`ok ${target} -> ${source}`);
      return;
    }
    if (!options.force) {
      throw new Error(`${target} is a symlink to ${current}; use --force to replace it`);
    }
    removeForLink(target, options);
  } else if (existing) {
    if (!options.migrate && !options.force) {
      throw new Error(`${target} exists; use --migrate to merge it or --force to move it aside`);
    }
    if (options.migrate) {
      copyMerge(target, source, options);
    }
    removeForLink(target, options);
  }

  ensureParent(target, options);
  if (options.dryRun) {
    console.log(`[dry-run] ln -s ${source} ${target}`);
  } else {
    fs.symlinkSync(source, target);
  }
}

async function setup(options) {
  const items = options.full ? fullSharedItems : defaultSharedItems;
  const sharedHome = path.resolve(options.sharedHome);
  const hasConfiguredHomes = options.accounts !== null || Boolean(options.homes) || Boolean(options.addApiKey);
  const shouldConfigureHomes =
    hasConfiguredHomes ||
    options.prune ||
    (!options.apiKeyMode && options.remove.length === 0 && !options.list);
  const homes = shouldConfigureHomes || options.list || options.remove.length > 0
    ? validateAccounts(accountHomes(options), sharedHome)
    : [];
  const selectedHomes = new Set(homes.map((account) => account.home));
  const discoveredAccounts = validateAccounts(discoverAccountHomes(), sharedHome);
  const removableAccounts = mergeAccounts(homes, discoveredAccounts);
  const activeHomes = activeCodexHomes();
  const removeTargets = [];
  let apiKeyAccount = null;

  if (options.list) {
    const accounts = hasConfiguredHomes ? homes : discoveredAccounts;
    printAccountList(accounts, sharedHome, options);
    return;
  }

  if (options.apiKeyMode) {
    writeLocalConfigPatch({ apiKeyMode: options.apiKeyMode }, options);
  }

  for (const selector of options.remove) {
    removeTargets.push(findRemoveTarget(selector, removableAccounts));
  }
  if (options.prune) {
    if (options.accounts === null && !options.homes) {
      throw new Error("--prune requires --accounts or --homes");
    }
    for (const account of removableAccounts) {
      if (!selectedHomes.has(account.home)) {
        removeTargets.push(account);
      }
    }
  }

  const uniqueRemoveTargets = [...new Map(removeTargets.map((account) => [account.home, account])).values()];
  const activeRemoveTargets = uniqueRemoveTargets.filter((account) => activeHomes.has(account.home));
  if (activeRemoveTargets.length > 0 && !options.allowActive && !options.dryRun) {
    throw new Error(
      `Refusing to remove active Codex homes: ${activeRemoveTargets.map((account) => account.home).join(", ")}. ` +
        "Exit those Codex sessions first, or rerun with --allow-active if you accept the risk.",
    );
  }
  for (const account of uniqueRemoveTargets) {
    removeAccountHome(account, options);
  }
  const removedHomes = new Set(uniqueRemoveTargets.map((account) => account.home));
  const remainingHomes = homes.filter((account) => !removedHomes.has(account.home));

  if (remainingHomes.length < 1) {
    if (options.apiKeyMode || uniqueRemoveTargets.length > 0) {
      return;
    }
    throw new Error("No account homes selected. Use --accounts <N> on a new machine, or --homes name=/path,...");
  }
  const activeTargets = remainingHomes.filter((account) => activeHomes.has(account.home));

  if (activeTargets.length > 0 && !options.allowActive && !options.dryRun) {
    throw new Error(
      `Refusing to modify active Codex homes: ${activeTargets.map((account) => account.home).join(", ")}. ` +
      "Exit those Codex sessions first, or rerun with --allow-active if you accept the risk.",
    );
  }

  if (options.addApiKey) {
    apiKeyAccount = remainingHomes.find((candidate) => candidate.name.toLowerCase() === options.addApiKey.toLowerCase());
    if (!apiKeyAccount) {
      throw new Error(`API-key account was not selected: ${options.addApiKey}`);
    }
    await preflightApiKeyAccount(apiKeyAccount, options);
  }

  ensureDir(sharedHome, options);

  for (const { home: accountHome } of remainingHomes) {
    ensureDir(accountHome, options);
    for (const item of items) {
      linkItem(accountHome, sharedHome, item, options);
    }
    console.log(`configured ${accountHome}`);
  }

  if (options.addApiKey) {
    await writeApiKeyAccount(apiKeyAccount, options);
  }

  console.log("\nNext steps:");
  for (const account of remainingHomes.filter((candidate) => candidate.name !== options.addApiKey)) {
    console.log(`  CODEX_HOME=${account.home} codex login`);
  }
  console.log("  cx status");
}

async function main() {
  try {
    await setup(parseArgs(process.argv.slice(2)));
  } catch (error) {
    console.error(`[cx-setup] ${error.message}`);
    process.exit(2);
  }
}

if (require.main === module) {
  main();
}

module.exports = {
  checkApiKeyEndpoint,
  defaultSharedItems,
  discoverAccountHomes,
  fullSharedItems,
  normalizeApiKeyCheckMode,
  normalizeApiKeyMode,
  normalizeOpenAiBaseUrl,
  parseArgs,
  parseHomes,
  setup,
  validateAccounts,
};
